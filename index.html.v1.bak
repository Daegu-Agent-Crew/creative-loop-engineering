<!--
&lt;!DOCTYPE html&gt;
&lt;html lang="ko"&gt;
&lt;head&gt;
&lt;meta charset="UTF-8"&gt;
&lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;
&lt;title&gt;창의적 루프 엔지니어링 시스템 — Creative Loop&lt;/title&gt;
&lt;style&gt;
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&amp;family=Noto+Sans+KR:wght@300;400;500;700;800&amp;display=swap');

  :root {
    — —bg: #0a0e17;
    — —surface: #111827;
    — —surface2: #1a2235;
    — —border: #1e293b;
    — —text: #e2e8f0;
    — —text2: #94a3b8;
    — —accent: #6366f1;
    — —accent2: #818cf8;
    — —green: #22c55e;
    — —green2: #16a34a;
    — —amber: #f59e0b;
    — —red: #ef4444;
    — —blue: #3b82f6;
    — —cyan: #06b6d4;
    — —pink: #ec4899;
    — —purple: #a855f7;
    — —orange: #f97316;
    — —glow: rgba(99,102,241,0.15);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Inter', 'Noto Sans KR', sans-serif;
    background: var(— —bg);
    color: var(— —text);
    line-height: 1.7;
    overflow-x: hidden;
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    background: radial-gradient(circle, var(— —glow) 0%, transparent 70%);
    top: -100px; left: 50%; transform: translateX(-50%);
    pointer-events: none;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, var(— —accent2), var(— —cyan), var(— —green));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
  }
  .hero .subtitle {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(— —text2);
    max-width: 700px;
    margin-bottom: 2rem;
  }
  .hero .quote {
    font-style: italic;
    color: var(— —amber);
    font-size: 1.1rem;
    max-width: 600px;
    border-left: 3px solid var(— —amber);
    padding-left: 1.2rem;
    text-align: left;
  }

  /* ===== NAV ===== */
  .nav {
    position: fixed; top:0; left:0; right:0;
    background: rgba(10,14,23,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(— —border);
    padding: 0.8rem 2rem;
    display: flex;
    gap: 1.5rem;
    z-index: 100;
    overflow-x: auto;
  }
  .nav a {
    color: var(— —text2);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    white-space: nowrap;
    transition: color 0.2s;
  }
  .nav a:hover, .nav a.active { color: var(— —accent2); }

  /* ===== SECTION ===== */
  section {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }
  section h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(— —accent2);
  }
  section h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(— —text);
    margin: 2rem 0 1rem;
  }
  .desc {
    color: var(— —text2);
    margin-bottom: 2rem;
    max-width: 800px;
  }

  /* ===== DIAGRAM CONTAINER ===== */
  .diagram {
    background: var(— —surface);
    border: 1px solid var(— —border);
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0;
    overflow-x: auto;
  }
  .diagram-title {
    font-size: 0.8rem;
    color: var(— —text2);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  /* ===== SVG DIAGRAMS ===== */
  svg text {
    font-family: 'Inter', 'Noto Sans KR', sans-serif;
  }

  /* ===== ARCHITECTURE ===== */
  .arch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .arch-card {
    background: var(— —surface);
    border: 1px solid var(— —border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: border-color 0.3s, transform 0.2s;
  }
  .arch-card:hover {
    border-color: var(— —accent);
    transform: translateY(-2px);
  }
  .arch-card .icon { font-size: 2rem; margin-bottom: 0.5rem; }
  .arch-card h4 { font-size: 1rem; color: var(— —accent2); margin-bottom: 0.3rem; }
  .arch-card p { font-size: 0.85rem; color: var(— —text2); }
  .arch-card .tag {
    display: inline-block;
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-top: 0.5rem;
    font-weight: 600;
  }
  .tag-automation { background: rgba(99,102,241,0.15); color: var(— —accent2); }
  .tag-memory { background: rgba(34,197,94,0.15); color: var(— —green); }
  .tag-skill { background: rgba(6,182,212,0.15); color: var(— —cyan); }
  .tag-eval { background: rgba(239,68,68,0.15); color: var(— —red); }
  .tag-agent { background: rgba(168,85,247,0.15); color: var(— —purple); }

  /* ===== LOOP VISUAL ===== */
  .loop-steps {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin: 2rem 0;
    flex-wrap: wrap;
    justify-content: center;
  }
  .loop-step {
    flex: 1;
    min-width: 140px;
    max-width: 200px;
    background: var(— —surface);
    border: 1px solid var(— —border);
    padding: 1.2rem 1rem;
    text-align: center;
    position: relative;
    transition: all 0.3s;
  }
  .loop-step:first-child { border-radius: 12px 0 0 12px; }
  .loop-step:last-child { border-radius: 0 12px 12px 0; }
  .loop-step:hover { border-color: var(— —accent); background: var(— —surface2); }
  .loop-step .step-num {
    display: inline-block;
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(— —accent);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    line-height: 28px;
    margin-bottom: 0.5rem;
  }
  .loop-step h4 { font-size: 0.9rem; margin-bottom: 0.3rem; }
  .loop-step p { font-size: 0.75rem; color: var(— —text2); }
  .loop-arrow {
    display: flex;
    align-items: center;
    color: var(— —accent);
    font-size: 1.2rem;
    padding: 0 0.2rem;
  }

  /* ===== PHASE DETAIL ===== */
  .phases {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }
  .phase {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .phase-badge {
    width: 100px; height: 100px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-weight: 700;
    position: sticky;
    top: 80px;
  }
  .phase-badge .num { font-size: 2rem; }
  .phase-badge .name { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; }
  .phase-content {
    background: var(— —surface);
    border: 1px solid var(— —border);
    border-radius: 12px;
    padding: 1.5rem;
  }
  .phase-content h4 { font-size: 1.1rem; margin-bottom: 0.8rem; }
  .phase-content p { font-size: 0.9rem; color: var(— —text2); margin-bottom: 0.8rem; }
  .phase-content ul {
    list-style: none;
    padding: 0;
  }
  .phase-content li {
    font-size: 0.85rem;
    color: var(— —text2);
    padding: 0.4rem 0;
    padding-left: 1.5rem;
    position: relative;
  }
  .phase-content li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(— —accent);
  }
  .gate {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: rgba(245,158,11,0.08);
    border: 1px dashed var(— —amber);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    margin-top: 1rem;
  }
  .gate-icon { font-size: 1.3rem; }
  .gate-text { font-size: 0.85rem; color: var(— —amber); }
  .gate-action { font-size: 0.75rem; color: var(— —text2); }

  /* ===== EVOLUTION ===== */
  .evo-timeline {
    position: relative;
    padding-left: 2rem;
    margin-top: 2rem;
  }
  .evo-timeline::before {
    content: '';
    position: absolute;
    left: 8px; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(— —accent), var(— —green), var(— —cyan));
  }
  .evo-item {
    position: relative;
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }
  .evo-item::before {
    content: '';
    position: absolute;
    left: -2rem; top: 6px;
    width: 18px; height: 18px;
    border-radius: 50%;
    background: var(— —accent);
    border: 3px solid var(— —bg);
  }
  .evo-item h4 { font-size: 1rem; color: var(— —accent2); }
  .evo-item p { font-size: 0.85rem; color: var(— —text2); }
  .evo-item .meta { font-size: 0.75rem; color: var(— —text2); margin-top: 0.3rem; }

  /* ===== FEEDBACK LOOP DIAGRAM ===== */
  .fb-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
  }
  .fb-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .fb-box {
    padding: 1rem 1.5rem;
    border-radius: 10px;
    border: 1px solid var(— —border);
    background: var(— —surface);
    text-align: center;
    min-width: 130px;
  }
  .fb-box h5 { font-size: 0.85rem; margin-bottom: 0.3rem; }
  .fb-box p { font-size: 0.75rem; color: var(— —text2); }
  .fb-arrow-h { color: var(— —accent); font-size: 1.5rem; }
  .fb-arrow-v { color: var(— —accent); font-size: 1.5rem; }
  .fb-loop-back {
    color: var(— —red);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    border: 1px dashed var(— —red);
    border-radius: 8px;
    background: rgba(239,68,68,0.05);
  }

  /* ===== COMPARISON TABLE ===== */
  .compare-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 2rem;
    font-size: 0.85rem;
  }
  .compare-table th {
    text-align: left;
    padding: 0.8rem 1rem;
    background: var(— —surface);
    border-bottom: 2px solid var(— —accent);
    color: var(— —accent2);
    font-weight: 600;
  }
  .compare-table td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(— —border);
    color: var(— —text2);
  }
  .compare-table tr:hover td { background: var(— —surface2); }

  /* ===== DIVIDER ===== */
  .divider {
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(— —border), transparent);
    margin: 3rem 0;
  }

  /* ===== FOOTER ===== */
  footer {
    text-align: center;
    padding: 3rem 2rem;
    color: var(— —text2);
    font-size: 0.8rem;
    border-top: 1px solid var(— —border);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 768px) {
    .phase { grid-template-columns: 1fr; }
    .phase-badge { position: static; width: 100%; height: auto; flex-direction: row; gap: 0.5rem; padding: 1rem; }
    .loop-steps { flex-direction: column; }
    .loop-step { max-width: 100%; border-radius: 12px !important; }
    .loop-arrow { transform: rotate(90deg); }
  }

  /* ===== CODE BLOCK ===== */
  .code {
    background: #0d1117;
    border: 1px solid var(— —border);
    border-radius: 8px;
    padding: 1rem 1.2rem;
    font-family: 'Fira Code', monospace;
    font-size: 0.8rem;
    color: #c9d1d9;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .code .comment { color: #8b949e; }
  .code .key { color: #79c0ff; }
  .code .val { color: #a5d6ff; }

  /* ===== HIGHLIGHT BOX ===== */
  .highlight {
    background: linear-gradient(135deg, rgba(99,102,241,0.08), rgba(34,197,94,0.08));
    border: 1px solid var(— —accent);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 2rem 0;
  }
  .highlight h4 { color: var(— —accent2); margin-bottom: 0.5rem; }
  .highlight p { font-size: 0.9rem; color: var(— —text2); }
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;

&lt;!— — NAV — —&gt;
&lt;nav class="nav" id="nav"&gt;
  &lt;a href="#overview"&gt;개요&lt;/a&gt;
  &lt;a href="#architecture"&gt;6가지 부품&lt;/a&gt;
  &lt;a href="#loop"&gt;루프 구조&lt;/a&gt;
  &lt;a href="#phases"&gt;5-Phase 파이프라인&lt;/a&gt;
  &lt;a href="#feedback"&gt;피드백 루프&lt;/a&gt;
  &lt;a href="#evolution"&gt;진화 구조&lt;/a&gt;
  &lt;a href="#example"&gt;삼체 만화 적용&lt;/a&gt;
  &lt;a href="#comparison"&gt;루프 vs 기존&lt;/a&gt;
  &lt;a href="#implementation"&gt;구현 계획&lt;/a&gt;
&lt;/nav&gt;

&lt;!— — HERO — —&gt;
&lt;header class="hero" id="top"&gt;
  &lt;h1&gt; 창의적 루프 엔지니어링 시스템&lt;/h1&gt;
  &lt;p class="subtitle"&gt;프롬프트를 짜는 게 아니라 시스템을 짜는 시대.&lt;br&gt;선택 몇 개로 창의적 결과물이 자동으로 만들어지는 진화형 파이프라인.&lt;/p&gt;
  &lt;p class="quote"&gt;
    "루프 엔지니어링이란, 에이전트에게 프롬프트를 쓰는 사람 자리에서 당신을 빼내는 것이다.&lt;br&gt;대신 그 일을 해줄 시스템을 당신이 설계한다."&lt;br&gt;— Addy Osmani
  &lt;/p&gt;
&lt;/header&gt;

&lt;!— — 1. OVERVIEW — —&gt;
&lt;section id="overview"&gt;
  &lt;h2&gt;📋 시스템 개요&lt;/h2&gt;
  &lt;p class="desc"&gt;
    이 문서는 "주제·화풍·분위기를 선택하면 중간 피드백 게이트를 거치며 점진적으로 완성되는 창의적 산출물 파이프라인"의 전체 설계도입니다.
    기반은 Addy Osmani의 Loop Engineering 6가지 부품 + 기존 랄프톤 생태계의 Phase Split 구조를 통합합니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;SYSTEM ARCHITECTURE — 전체 시스템 구조도&lt;/div&gt;
    &lt;svg viewBox="0 0 1000 520" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;"&gt;
      &lt;!— — Background — —&gt;
      &lt;defs&gt;
        &lt;linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%"&gt;
          &lt;stop offset="0%" style="stop-color:#111827"/&gt;
          &lt;stop offset="100%" style="stop-color:#1a2235"/&gt;
        &lt;/linearGradient&gt;
        &lt;filter id="glow"&gt;
          &lt;feGaussianBlur stdDeviation="3" result="blur"/&gt;
          &lt;feComposite in="SourceGraphic" in2="blur" operator="over"/&gt;
        &lt;/filter&gt;
      &lt;/defs&gt;

      &lt;!— — Human Input Box — —&gt;
      &lt;rect x="30" y="30" width="200" height="120" rx="12" fill="#1e293b" stroke="#6366f1" stroke-width="2"/&gt;
      &lt;text x="130" y="60" text-anchor="middle" fill="#818cf8" font-size="14" font-weight="700"&gt;👤 주인님 (감독관)&lt;/text&gt;
      &lt;text x="130" y="82" text-anchor="middle" fill="#94a3b8" font-size="11"&gt;주제 · 화풍 · 분위기&lt;/text&gt;
      &lt;text x="130" y="100" text-anchor="middle" fill="#94a3b8" font-size="11"&gt;포맷 · 해상도 · 타겟&lt;/text&gt;
      &lt;text x="130" y="118" text-anchor="middle" fill="#94a3b8" font-size="11"&gt;참고 이미지&lt;/text&gt;

      &lt;!— — Arrow from Human — —&gt;
      &lt;line x1="230" y1="90" x2="290" y2="90" stroke="#6366f1" stroke-width="2" marker-end="url(#arrow)"/&gt;
      &lt;text x="260" y="80" text-anchor="middle" fill="#6366f1" font-size="9"&gt;설정&lt;/text&gt;

      &lt;!— — Main Pipeline — —&gt;
      &lt;rect x="290" y="20" width="420" height="480" rx="16" fill="url(#bgGrad)" stroke="#334155" stroke-width="1" stroke-dasharray="5,5"/&gt;
      &lt;text x="500" y="45" text-anchor="middle" fill="#6366f1" font-size="13" font-weight="700"&gt;Creative Loop Engine&lt;/text&gt;

      &lt;!— — Phase 1: Define — —&gt;
      &lt;rect x="310" y="60" width="380" height="55" rx="8" fill="#1e293b" stroke="#6366f1" stroke-width="1.5"/&gt;
      &lt;text x="325" y="83" fill="#818cf8" font-size="11" font-weight="600"&gt;① DEFINE&lt;/text&gt;
      &lt;text x="325" y="100" fill="#94a3b8" font-size="10"&gt;PRD 자동 생성 · 캐릭터 설정 · 스타일 가이드&lt;/text&gt;

      &lt;!— — Gate 1 — —&gt;
      &lt;rect x="335" y="120" width="80" height="22" rx="4" fill="rgba(245,158,11,0.15)" stroke="#f59e0b" stroke-width="1"/&gt;
      &lt;text x="375" y="135" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="600"&gt;GATE ✋&lt;/text&gt;

      &lt;!— — Phase 2: Sample — —&gt;
      &lt;rect x="310" y="150" width="380" height="55" rx="8" fill="#1e293b" stroke="#06b6d4" stroke-width="1.5"/&gt;
      &lt;text x="325" y="173" fill="#06b6d4" font-size="11" font-weight="600"&gt;② SAMPLE&lt;/text&gt;
      &lt;text x="325" y="190" fill="#94a3b8" font-size="10"&gt;대표 캐릭터/장면 샘플 3종 생성 · 화풍 확정&lt;/text&gt;

      &lt;!— — Gate 2 — —&gt;
      &lt;rect x="335" y="210" width="80" height="22" rx="4" fill="rgba(245,158,11,0.15)" stroke="#f59e0b" stroke-width="1"/&gt;
      &lt;text x="375" y="225" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="600"&gt;GATE ✋&lt;/text&gt;

      &lt;!— — Phase 3: Produce — —&gt;
      &lt;rect x="310" y="240" width="380" height="55" rx="8" fill="#1e293b" stroke="#22c55e" stroke-width="1.5"/&gt;
      &lt;text x="325" y="263" fill="#22c55e" font-size="11" font-weight="600"&gt;③ PRODUCE&lt;/text&gt;
      &lt;text x="325" y="280" fill="#94a3b8" font-size="10"&gt;전체 컷 생성 (서브에이전트 병렬) · 중간 체크포인트&lt;/text&gt;

      &lt;!— — Gate 3 — —&gt;
      &lt;rect x="335" y="300" width="80" height="22" rx="4" fill="rgba(245,158,11,0.15)" stroke="#f59e0b" stroke-width="1"/&gt;
      &lt;text x="375" y="315" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="600"&gt;GATE ✋&lt;/text&gt;

      &lt;!— — Phase 4: Refine — —&gt;
      &lt;rect x="310" y="330" width="380" height="55" rx="8" fill="#1e293b" stroke="#a855f7" stroke-width="1.5"/&gt;
      &lt;text x="325" y="353" fill="#a855f7" font-size="11" font-weight="600"&gt;④ REFINE&lt;/text&gt;
      &lt;text x="325" y="370" fill="#94a3b8" font-size="10"&gt;피드백 반영 수정 · Critic 평가 · v(N+1) 생성&lt;/text&gt;

      &lt;!— — Gate 4 — —&gt;
      &lt;rect x="335" y="390" width="80" height="22" rx="4" fill="rgba(245,158,11,0.15)" stroke="#f59e0b" stroke-width="1"/&gt;
      &lt;text x="375" y="405" text-anchor="middle" fill="#f59e0b" font-size="9" font-weight="600"&gt;GATE ✋&lt;/text&gt;

      &lt;!— — Phase 5: Deliver — —&gt;
      &lt;rect x="310" y="420" width="380" height="55" rx="8" fill="#1e293b" stroke="#ec4899" stroke-width="1.5"/&gt;
      &lt;text x="325" y="443" fill="#ec4899" font-size="11" font-weight="600"&gt;⑤ DELIVER&lt;/text&gt;
      &lt;text x="325" y="460" fill="#94a3b8" font-size="10"&gt;최종 산출물 + 메타데이터 + 진화 기록&lt;/text&gt;

      &lt;!— — Refinement Loop Arrow — —&gt;
      &lt;path d="M 690 355 Q 720 355 720 300 L 720 175 Q 720 150 695 150" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowRed)"/&gt;
      &lt;text x="735" y="260" fill="#ef4444" font-size="9" transform="rotate(-90, 735, 260)"&gt;재시도 루프&lt;/text&gt;

      &lt;!— — Sub-Agent Box — —&gt;
      &lt;rect x="750" y="140" width="220" height="180" rx="12" fill="#1e293b" stroke="#a855f7" stroke-width="1.5"/&gt;
      &lt;text x="860" y="165" text-anchor="middle" fill="#a855f7" font-size="12" font-weight="700"&gt;🤖 서브에이전트&lt;/text&gt;

      &lt;rect x="765" y="180" width="90" height="35" rx="6" fill="#334155"/&gt;
      &lt;text x="810" y="195" text-anchor="middle" fill="#22c55e" font-size="10"&gt;Writer&lt;/text&gt;
      &lt;text x="810" y="208" text-anchor="middle" fill="#94a3b8" font-size="8"&gt;생성&lt;/text&gt;

      &lt;rect x="865" y="180" width="90" height="35" rx="6" fill="#334155"/&gt;
      &lt;text x="910" y="195" text-anchor="middle" fill="#ef4444" font-size="10"&gt;Evaluator&lt;/text&gt;
      &lt;text x="910" y="208" text-anchor="middle" fill="#94a3b8" font-size="8"&gt;평가&lt;/text&gt;

      &lt;rect x="765" y="225" width="90" height="35" rx="6" fill="#334155"/&gt;
      &lt;text x="810" y="240" text-anchor="middle" fill="#f59e0b" font-size="10"&gt;Critic&lt;/text&gt;
      &lt;text x="810" y="253" text-anchor="middle" fill="#94a3b8" font-size="8"&gt;비판&lt;/text&gt;

      &lt;rect x="865" y="225" width="90" height="35" rx="6" fill="#334155"/&gt;
      &lt;text x="910" y="240" text-anchor="middle" fill="#06b6d4" font-size="10"&gt;Researcher&lt;/text&gt;
      &lt;text x="910" y="253" text-anchor="middle" fill="#94a3b8" font-size="8"&gt;조사&lt;/text&gt;

      &lt;rect x="765" y="270" width="190" height="30" rx="6" fill="#334155"/&gt;
      &lt;text x="860" y="289" text-anchor="middle" fill="#94a3b8" font-size="9"&gt;Planner (설계 + 오케스트레이션)&lt;/text&gt;

      &lt;!— — Output Box — —&gt;
      &lt;rect x="750" y="380" width="220" height="100" rx="12" fill="#1e293b" stroke="#22c55e" stroke-width="1.5"/&gt;
      &lt;text x="860" y="405" text-anchor="middle" fill="#22c55e" font-size="12" font-weight="700"&gt;📦 산출물&lt;/text&gt;
      &lt;text x="770" y="430" fill="#94a3b8" font-size="10"&gt;• 이미지/만화/디자인&lt;/text&gt;
      &lt;text x="770" y="448" fill="#94a3b8" font-size="10"&gt;• 메타데이터 (어떤 선택이 왜 좋았는지)&lt;/text&gt;
      &lt;text x="770" y="466" fill="#94a3b8" font-size="10"&gt;• 진화 로그 (v1→v2→... 변경 이력)&lt;/text&gt;

      &lt;!— — State File Box — —&gt;
      &lt;rect x="30" y="200" width="200" height="140" rx="12" fill="#1e293b" stroke="#22c55e" stroke-width="1.5"/&gt;
      &lt;text x="130" y="225" text-anchor="middle" fill="#22c55e" font-size="12" font-weight="700"&gt;💾 상태 파일&lt;/text&gt;
      &lt;text x="50" y="250" fill="#94a3b8" font-size="10"&gt;config.json — 설정&lt;/text&gt;
      &lt;text x="50" y="268" fill="#94a3b8" font-size="10"&gt;progress.md — 진행 상태&lt;/text&gt;
      &lt;text x="50" y="286" fill="#94a3b8" font-size="10"&gt;feedback.md — 피드백 기록&lt;/text&gt;
      &lt;text x="50" y="304" fill="#94a3b8" font-size="10"&gt;evolution.md — 진화 로그&lt;/text&gt;
      &lt;text x="50" y="322" fill="#94a3b8" font-size="10"&gt;scores.json — 평가 점수&lt;/text&gt;

      &lt;!— — Arrow from State — —&gt;
      &lt;line x1="230" y1="270" x2="290" y2="270" stroke="#22c55e" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowGreen)"/&gt;

      &lt;!— — Skill File Box — —&gt;
      &lt;rect x="30" y="380" width="200" height="100" rx="12" fill="#1e293b" stroke="#06b6d4" stroke-width="1.5"/&gt;
      &lt;text x="130" y="405" text-anchor="middle" fill="#06b6d4" font-size="12" font-weight="700"&gt;📜 SKILL.md&lt;/text&gt;
      &lt;text x="50" y="430" fill="#94a3b8" font-size="10"&gt;• 프로젝트 인수인계 노트&lt;/text&gt;
      &lt;text x="50" y="448" fill="#94a3b8" font-size="10"&gt;• 화풍 가이드 · 프롬프트 템플릿&lt;/text&gt;
      &lt;text x="50" y="466" fill="#94a3b8" font-size="10"&gt;• 평가 기준 · 품질 체크리스트&lt;/text&gt;

      &lt;!— — Arrow from Skill — —&gt;
      &lt;line x1="230" y1="430" x2="290" y2="430" stroke="#06b6d4" stroke-width="1.5" stroke-dasharray="4,3" marker-end="url(#arrowCyan)"/&gt;

      &lt;!— — Arrow markers — —&gt;
      &lt;defs&gt;
        &lt;marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#6366f1"/&gt;
        &lt;/marker&gt;
        &lt;marker id="arrowRed" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#ef4444"/&gt;
        &lt;/marker&gt;
        &lt;marker id="arrowGreen" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#22c55e"/&gt;
        &lt;/marker&gt;
        &lt;marker id="arrowCyan" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#06b6d4"/&gt;
        &lt;/marker&gt;
      &lt;/defs&gt;
    &lt;/svg&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 2. ARCHITECTURE — 6 PARTS — —&gt;
&lt;section id="architecture"&gt;
  &lt;h2&gt;🧩 루프의 6가지 부품&lt;/h2&gt;
  &lt;p class="desc"&gt;
    Addy Osmani가 정의한 루프 엔지니어링의 핵심 부품 5개 + 기억장치 1개를 창의적 파이프라인에 맞게 적용합니다.
  &lt;/p&gt;

  &lt;div class="arch-grid"&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;⏰&lt;/div&gt;
      &lt;h4&gt;① 오토메이션&lt;/h4&gt;
      &lt;p&gt;정해진 조건에서 루프를 자동 시작. 주기 반복(cron), 조건 만족까지(goal), 이벤트 트리거(hooks)&lt;/p&gt;
      &lt;span class="tag tag-automation"&gt;자동 시작&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;🌳&lt;/div&gt;
      &lt;h4&gt;② 워크트리&lt;/h4&gt;
      &lt;p&gt;버전별로 독립 작업 폴더 생성. v1/v2/v3가 충돌 없이 병렬 작업 가능&lt;/p&gt;
      &lt;span class="tag tag-automation"&gt;격리&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;📜&lt;/div&gt;
      &lt;h4&gt;③ 스킬 (SKILL.md)&lt;/h4&gt;
      &lt;p&gt;프로젝트 지식을 파일에 적어두고 AI가 매 작업마다 읽고 시작. 인수인계 노트&lt;/p&gt;
      &lt;span class="tag tag-skill"&gt;재사용&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;🔌&lt;/div&gt;
      &lt;h4&gt;④ 커넥터&lt;/h4&gt;
      &lt;p&gt;외부 도구 연결. GitHub, 이미지 API, 프롬프트 모델, 배포 파이프라인&lt;/p&gt;
      &lt;span class="tag tag-skill"&gt;손발&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;🤖&lt;/div&gt;
      &lt;h4&gt;⑤ 서브에이전트&lt;/h4&gt;
      &lt;p&gt;만드는 AI와 검사하는 AI를 분리. 자기 채점 후한 편향을 독립 평가로 보정&lt;/p&gt;
      &lt;span class="tag tag-eval"&gt;검증&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="arch-card"&gt;
      &lt;div class="icon"&gt;💾&lt;/div&gt;
      &lt;h4&gt;⑥ 상태 파일 (기억)&lt;/h4&gt;
      &lt;p&gt;에이전트는 잊어도 저장소는 잊지 않는다. 진행/피드백/평가/진화를 디스크에 기록&lt;/p&gt;
      &lt;span class="tag tag-memory"&gt;기억&lt;/span&gt;
    &lt;/div&gt;
  &lt;/div&gt;

  &lt;div class="highlight"&gt;
    &lt;h4&gt;💡 창의적 파이프라인에의 적용&lt;/h4&gt;
    &lt;p&gt;이 6가지 부품을 창의적 작업(만화, 일러스트, 디자인 등)에 맞게 재조합합니다. 코드가 아니라 콘텐츠를 만들지만, "발견→분류→수정→검증"의 루프 구조는 동일합니다.&lt;/p&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 3. LOOP STRUCTURE — —&gt;
&lt;section id="loop"&gt;
  &lt;h2&gt;🔄 루프 구조 — 한 바퀴의 4단계&lt;/h2&gt;
  &lt;p class="desc"&gt;
    하나의 루프는 발견→분류→수정→검증 네 동작으로 압축됩니다. 각 단계 끝에 자동/수동 피드백 게이트가 있습니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;LOOP CYCLE — 루프 한 바퀴&lt;/div&gt;
    &lt;svg viewBox="0 0 800 320" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;"&gt;
      &lt;!— — Central Loop — —&gt;
      &lt;circle cx="400" cy="160" r="120" fill="none" stroke="#334155" stroke-width="2" stroke-dasharray="8,4"/&gt;

      &lt;!— — Discover — —&gt;
      &lt;circle cx="400" cy="40" r="40" fill="#1e293b" stroke="#6366f1" stroke-width="2"/&gt;
      &lt;text x="400" y="37" text-anchor="middle" fill="#818cf8" font-size="11" font-weight="700"&gt;🔍&lt;/text&gt;
      &lt;text x="400" y="52" text-anchor="middle" fill="#818cf8" font-size="9"&gt;발견&lt;/text&gt;

      &lt;!— — Triage — —&gt;
      &lt;circle cx="520" cy="160" r="40" fill="#1e293b" stroke="#06b6d4" stroke-width="2"/&gt;
      &lt;text x="520" y="157" text-anchor="middle" fill="#06b6d4" font-size="11" font-weight="700"&gt;📋&lt;/text&gt;
      &lt;text x="520" y="172" text-anchor="middle" fill="#06b6d4" font-size="9"&gt;분류&lt;/text&gt;

      &lt;!— — Modify — —&gt;
      &lt;circle cx="400" cy="280" r="40" fill="#1e293b" stroke="#22c55e" stroke-width="2"/&gt;
      &lt;text x="400" y="277" text-anchor="middle" fill="#22c55e" font-size="11" font-weight="700"&gt;✏️&lt;/text&gt;
      &lt;text x="400" y="292" text-anchor="middle" fill="#22c55e" font-size="9"&gt;수정&lt;/text&gt;

      &lt;!— — Verify — —&gt;
      &lt;circle cx="280" cy="160" r="40" fill="#1e293b" stroke="#ef4444" stroke-width="2"/&gt;
      &lt;text x="280" y="157" text-anchor="middle" fill="#ef4444" font-size="11" font-weight="700"&gt;✅&lt;/text&gt;
      &lt;text x="280" y="172" text-anchor="middle" fill="#ef4444" font-size="9"&gt;검증&lt;/text&gt;

      &lt;!— — Arrows — —&gt;
      &lt;path d="M 435 55 Q 490 90 505 125" fill="none" stroke="#6366f1" stroke-width="1.5" marker-end="url(#loopArrow)"/&gt;
      &lt;path d="M 510 200 Q 490 250 435 265" fill="none" stroke="#06b6d4" stroke-width="1.5" marker-end="url(#loopArrow)"/&gt;
      &lt;path d="M 365 265 Q 310 250 290 200" fill="none" stroke="#22c55e" stroke-width="1.5" marker-end="url(#loopArrow)"/&gt;
      &lt;path d="M 295 125 Q 310 90 365 55" fill="none" stroke="#ef4444" stroke-width="1.5" marker-end="url(#loopArrow)"/&gt;

      &lt;!— — Rejection Loop — —&gt;
      &lt;path d="M 340 280 Q 200 280 180 200 Q 160 130 200 70 Q 240 30 360 35" fill="none" stroke="#ef4444" stroke-width="1" stroke-dasharray="4,3" marker-end="url(#arrowRed)"/&gt;
      &lt;text x="170" y="170" fill="#ef4444" font-size="9" transform="rotate(-90,170,170)"&gt;불통과 → 재시도&lt;/text&gt;

      &lt;!— — Center Text — —&gt;
      &lt;text x="400" y="155" text-anchor="middle" fill="#94a3b8" font-size="10"&gt;진화 카운터&lt;/text&gt;
      &lt;text x="400" y="175" text-anchor="middle" fill="#818cf8" font-size="16" font-weight="700"&gt;vN&lt;/text&gt;

      &lt;!— — Side Labels — —&gt;
      &lt;text x="600" y="60" fill="#94a3b8" font-size="10"&gt;① 발견&lt;/text&gt;
      &lt;text x="600" y="75" fill="#64748b" font-size="9"&gt;주제 분석 · 참고 수집 · 스타일 리서치&lt;/text&gt;

      &lt;text x="600" y="120" fill="#94a3b8" font-size="10"&gt;② 분류&lt;/text&gt;
      &lt;text x="600" y="135" fill="#64748b" font-size="9"&gt;프롬프트 설계 · 생성 계획 · 우선순위&lt;/text&gt;

      &lt;text x="600" y="200" fill="#94a3b8" font-size="10"&gt;③ 수정&lt;/text&gt;
      &lt;text x="600" y="215" fill="#64748b" font-size="9"&gt;이미지/콘텐츠 생성 · 피드백 반영&lt;/text&gt;

      &lt;text x="600" y="270" fill="#94a3b8" font-size="10"&gt;④ 검증&lt;/text&gt;
      &lt;text x="600" y="285" fill="#64748b" font-size="9"&gt;Critic 평가 · 품질 점수 · 승인/거부&lt;/text&gt;

      &lt;defs&gt;
        &lt;marker id="loopArrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#64748b"/&gt;
        &lt;/marker&gt;
      &lt;/defs&gt;
    &lt;/svg&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 4. 5-PHASE PIPELINE — —&gt;
&lt;section id="phases"&gt;
  &lt;h2&gt;📊 5-Phase 창의적 파이프라인&lt;/h2&gt;
  &lt;p class="desc"&gt;
    루프의 4단계를 실제 창의적 작업에 맞게 5개 Phase로 확장합니다. 각 Phase 끝에 피드백 게이트(✋)가 있어 주인님이 검토할 수 있습니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;PHASE DETAIL — 각 Phase의 입력/출력/게이트&lt;/div&gt;

    &lt;div class="loop-steps"&gt;
      &lt;div class="loop-step" style="border-color: var(— —accent);"&gt;
        &lt;div class="step-num"&gt;1&lt;/div&gt;
        &lt;h4 style="color:var(— —accent2)"&gt;DEFINE&lt;/h4&gt;
        &lt;p&gt;설계 단계&lt;/p&gt;
      &lt;/div&gt;
      &lt;div class="loop-arrow"&gt;→&lt;/div&gt;
      &lt;div class="loop-step" style="border-color: var(— —cyan);"&gt;
        &lt;div class="step-num" style="background:var(— —cyan)"&gt;2&lt;/div&gt;
        &lt;h4 style="color:var(— —cyan)"&gt;SAMPLE&lt;/h4&gt;
        &lt;p&gt;샘플 생성&lt;/p&gt;
      &lt;/div&gt;
      &lt;div class="loop-arrow"&gt;→&lt;/div&gt;
      &lt;div class="loop-step" style="border-color: var(— —green);"&gt;
        &lt;div class="step-num" style="background:var(— —green)"&gt;3&lt;/div&gt;
        &lt;h4 style="color:var(— —green)"&gt;PRODUCE&lt;/h4&gt;
        &lt;p&gt;전체 생성&lt;/p&gt;
      &lt;/div&gt;
      &lt;div class="loop-arrow"&gt;→&lt;/div&gt;
      &lt;div class="loop-step" style="border-color: var(— —purple);"&gt;
        &lt;div class="step-num" style="background:var(— —purple)"&gt;4&lt;/div&gt;
        &lt;h4 style="color:var(— —purple)"&gt;REFINE&lt;/h4&gt;
        &lt;p&gt;수정·진화&lt;/p&gt;
      &lt;/div&gt;
      &lt;div class="loop-arrow"&gt;→&lt;/div&gt;
      &lt;div class="loop-step" style="border-color: var(— —pink);"&gt;
        &lt;div class="step-num" style="background:var(— —pink)"&gt;5&lt;/div&gt;
        &lt;h4 style="color:var(— —pink)"&gt;DELIVER&lt;/h4&gt;
        &lt;p&gt;최종 산출&lt;/p&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;

  &lt;div class="phases"&gt;
    &lt;!— — Phase 1 — —&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:linear-gradient(135deg,rgba(99,102,241,0.2),rgba(99,102,241,0.05)); border:2px solid var(— —accent);"&gt;
        &lt;span class="num" style="color:var(— —accent2)"&gt;1&lt;/span&gt;
        &lt;span class="name" style="color:var(— —accent2)"&gt;DEFINE&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content" style="border-color: var(— —accent);"&gt;
        &lt;h4&gt;📋 기획 &amp; 설계&lt;/h4&gt;
        &lt;p&gt;주인님이 선택한 주제/화풍/분위기를 바탕으로 PRD를 자동 생성합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;주인님 입력: 주제, 소제목, 화풍, 분위기, 포맷, 해상도&lt;/li&gt;
          &lt;li&gt;Planner 서브에이전트가 PRD 자동 생성&lt;/li&gt;
          &lt;li&gt;Researcher가 참고 자료·스타일 리서치&lt;/li&gt;
          &lt;li&gt;캐릭터 설정 시트, 화풍 가이드, 프롬프트 템플릿 생성&lt;/li&gt;
          &lt;li&gt;출력: &lt;code&gt;config.json&lt;/code&gt; + &lt;code&gt;PRD.md&lt;/code&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;div class="gate"&gt;
          &lt;span class="gate-icon"&gt;✋&lt;/span&gt;
          &lt;div&gt;
            &lt;div class="gate-text"&gt;게이트 1: 기획 승인&lt;/div&gt;
            &lt;div class="gate-action"&gt;주인님이 PRD 확인 → 수정/승인&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;!— — Phase 2 — —&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:linear-gradient(135deg,rgba(6,182,212,0.2),rgba(6,182,212,0.05)); border:2px solid var(— —cyan);"&gt;
        &lt;span class="num" style="color:var(— —cyan)"&gt;2&lt;/span&gt;
        &lt;span class="name" style="color:var(— —cyan)"&gt;SAMPLE&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content" style="border-color: var(— —cyan);"&gt;
        &lt;h4&gt;🎨 샘플 생성 &amp; 화풍 확정&lt;/h4&gt;
        &lt;p&gt;대표 장면 3~5종을 샘플로 생성합니다. 화풀이 확정되는 단계입니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;Writer가 프롬프트 생성 → 이미지 API로 샘플 생성&lt;/li&gt;
          &lt;li&gt;서로 다른 화풍/구도/빛 조건으로 A/B/C 버전 생성&lt;/li&gt;
          &lt;li&gt;캐릭터 시트 기반으로 주요 캐릭터 샘플&lt;/li&gt;
          &lt;li&gt;배경, 분위기, 컬러 팔레트 테스트&lt;/li&gt;
          &lt;li&gt;출력: &lt;code&gt;samples/v1/&lt;/code&gt; (3~5장)&lt;/li&gt;
        &lt;/ul&gt;
        &lt;div class="gate"&gt;
          &lt;span class="gate-icon"&gt;✋&lt;/span&gt;
          &lt;div&gt;
            &lt;div class="gate-text"&gt;게이트 2: 화풍 &amp; 방향 승인&lt;/div&gt;
            &lt;div class="gate-action"&gt;"A 버전 좋아" / "B에 C의 색감 섞어" / "다시" → 피드백이 Phase 3 입력으로&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;!— — Phase 3 — —&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:linear-gradient(135deg,rgba(34,197,94,0.2),rgba(34,197,94,0.05)); border:2px solid var(— —green);"&gt;
        &lt;span class="num" style="color:var(— —green)"&gt;3&lt;/span&gt;
        &lt;span class="name" style="color:var(— —green)"&gt;PRODUCE&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content" style="border-color: var(— —green);"&gt;
        &lt;h4&gt;🏭 전체 컷 생성 (본제작)&lt;/h4&gt;
        &lt;p&gt;승인된 샘플의 스타일로 전체 컷을 생성합니다. 서브에이전트가 병렬로 작업합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;전체 컷 목록(auto-generated from PRD)을 배치&lt;/li&gt;
          &lt;li&gt;Writer 서브에이전트: 컷별 프롬프트 생성&lt;/li&gt;
          &lt;li&gt;이미지 API 병렬 호출 (timeout 관리)&lt;/li&gt;
          &lt;li&gt;중간 체크포인트: 10컷마다 Evaluator 자동 검토&lt;/li&gt;
          &lt;li&gt;컷 간 일관성 검사 (캐릭터 얼굴, 색감, 배경)&lt;/li&gt;
          &lt;li&gt;출력: &lt;code&gt;output/v1/pages/&lt;/code&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;div class="gate"&gt;
          &lt;span class="gate-icon"&gt;✋&lt;/span&gt;
          &lt;div&gt;
            &lt;div class="gate-text"&gt;게이트 3: 중간 검토&lt;/div&gt;
            &lt;div class="gate-action"&gt;진행 상황 확인 + 방향 수정 가능 / "이거 계속 해" / "방향 바꿔"&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;!— — Phase 4 — —&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:linear-gradient(135deg,rgba(168,85,247,0.2),rgba(168,85,247,0.05)); border:2px solid var(— —purple);"&gt;
        &lt;span class="num" style="color:var(— —purple)"&gt;4&lt;/span&gt;
        &lt;span class="name" style="color:var(— —purple)"&gt;REFINE&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content" style="border-color: var(— —purple);"&gt;
        &lt;h4&gt;🔧 수정 &amp; 진화&lt;/h4&gt;
        &lt;p&gt;피드백을 반영하여 v(N+1)을 생성합니다. 이 단계가 루프의 핵심입니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;주인님 피드백을 &lt;code&gt;feedback.md&lt;/code&gt;에 기록&lt;/li&gt;
          &lt;li&gt;Critic 서브에이전트: 현재 버전 비판적 평가&lt;/li&gt;
          &lt;li&gt;Writer: 피드백 + Critic 분석 → 수정 프롬프트 생성&lt;/li&gt;
          &lt;li&gt;Evaluator: v(N) vs v(N+1) 비교 평가 → 점수 산출&lt;/li&gt;
          &lt;li&gt;점수가 기준 미달이면 자동으로 Phase 4 반복 (최대 N회)&lt;/li&gt;
          &lt;li&gt;출력: &lt;code&gt;output/v2/&lt;/code&gt;, &lt;code&gt;scores.json&lt;/code&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;div class="gate"&gt;
          &lt;span class="gate-icon"&gt;✋&lt;/span&gt;
          &lt;div&gt;
            &lt;div class="gate-text"&gt;게이트 4: 최종 승인&lt;/div&gt;
            &lt;div class="gate-action"&gt;"이걸로 간다" (DELIVER) / "아직 부족해" (REFINE 루프)&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;!— — Phase 5 — —&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:linear-gradient(135deg,rgba(236,72,153,0.2),rgba(236,72,153,0.05)); border:2px solid var(— —pink);"&gt;
        &lt;span class="num" style="color:var(— —pink)"&gt;5&lt;/span&gt;
        &lt;span class="name" style="color:var(— —pink)"&gt;DELIVER&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content" style="border-color: var(— —pink);"&gt;
        &lt;h4&gt;📦 최종 산출 &amp; 메타데이터&lt;/h4&gt;
        &lt;p&gt;최종 산출물과 함께 "무엇이 좋았는지"를 기록합니다. 다음 프로젝트의 진화 재료가 됩니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;최종 이미지/콘텐츠 정리 및 저장&lt;/li&gt;
          &lt;li&gt;메타데이터 생성: 어떤 선택이 왜 좋았는지&lt;/li&gt;
          &lt;li&gt;진화 로그: v1→v2→v3 변경 이력 + 이유&lt;/li&gt;
          &lt;li&gt;평가 요약: Critic/Evaluator 점수 추이&lt;/li&gt;
          &lt;li&gt;SKILL.md 자동 업데이트 (학습된 패턴 반영)&lt;/li&gt;
          &lt;li&gt;GitHub 배포 / 웹 게시&lt;/li&gt;
          &lt;li&gt;출력: &lt;code&gt;output/final/&lt;/code&gt;, &lt;code&gt;evolution.md&lt;/code&gt;&lt;/li&gt;
        &lt;/ul&gt;
        &lt;div class="gate" style="border-color:var(— —green); background:rgba(34,197,94,0.08);"&gt;
          &lt;span class="gate-icon"&gt;✅&lt;/span&gt;
          &lt;div&gt;
            &lt;div class="gate-text" style="color:var(— —green)"&gt;완료 — 진화 데이터가 다음 루프의 입력으로&lt;/div&gt;
            &lt;div class="gate-action"&gt;이번 프로젝트에서 학습한 패턴이 SKILL.md에 누적 → 다음 프로젝트의 품질 기준 상향&lt;/div&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 5. FEEDBACK LOOP — —&gt;
&lt;section id="feedback"&gt;
  &lt;h2&gt;🔁 피드백 루프 상세&lt;/h2&gt;
  &lt;p class="desc"&gt;
    루프의 핵심은 "만드는 AI와 검사하는 AI를 분리"하는 것입니다. Claude가 자기 결과를 후하게 평가하는 경향(self-bias)을 독립 평가자로 보정합니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;FEEDBACK LOOP DETAIL — 피드백 게이트 &amp; 재시도 구조&lt;/div&gt;

    &lt;div class="fb-diagram"&gt;
      &lt;!— — Top: Write — —&gt;
      &lt;div class="fb-row"&gt;
        &lt;div class="fb-box" style="border-color:var(— —green);"&gt;
          &lt;h5 style="color:var(— —green)"&gt;Writer&lt;/h5&gt;
          &lt;p&gt;프롬프트 생성 → 이미지/콘텐츠 생성&lt;/p&gt;
        &lt;/div&gt;
        &lt;span class="fb-arrow-h"&gt;→&lt;/span&gt;
        &lt;div class="fb-box" style="border-color:var(— —red);"&gt;
          &lt;h5 style="color:var(— —red)"&gt;Evaluator&lt;/h5&gt;
          &lt;p&gt;일관성·품질·스타일 준수도 평가&lt;/p&gt;
        &lt;/div&gt;
        &lt;span class="fb-arrow-h"&gt;→&lt;/span&gt;
        &lt;div class="fb-box" style="border-color:var(— —amber);"&gt;
          &lt;h5 style="color:var(— —amber)"&gt;Critic&lt;/h5&gt;
          &lt;p&gt;비판적 분석 · 개선점 도출&lt;/p&gt;
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;span class="fb-arrow-v"&gt;↓&lt;/span&gt;

      &lt;!— — Middle: Decision — —&gt;
      &lt;div class="fb-row"&gt;
        &lt;div class="fb-box" style="border-color:var(— —amber); width:300px;"&gt;
          &lt;h5 style="color:var(— —amber)"&gt;✋ 피드백 게이트&lt;/h5&gt;
          &lt;p&gt;점수 ≥ 기준 → 통과 | 점수 &amp;lt; 기준 → 수정 루프&lt;/p&gt;
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;span class="fb-arrow-v"&gt;↓&lt;/span&gt;

      &lt;!— — Bottom: Two Paths — —&gt;
      &lt;div class="fb-row" style="gap:3rem;"&gt;
        &lt;div style="text-align:center;"&gt;
          &lt;div class="fb-box" style="border-color:var(— —green); min-width:180px;"&gt;
            &lt;h5 style="color:var(— —green)"&gt;✅ 통과&lt;/h5&gt;
            &lt;p&gt;다음 Phase로 진행&lt;/p&gt;
          &lt;/div&gt;
        &lt;/div&gt;
        &lt;div style="text-align:center;"&gt;
          &lt;div class="fb-box" style="border-color:var(— —red); min-width:180px;"&gt;
            &lt;h5 style="color:var(— —red)"&gt;❌ 불통과&lt;/h5&gt;
            &lt;p&gt;피드백 + 수정 → 재생성&lt;/p&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/div&gt;

      &lt;!— — Loop Back — —&gt;
      &lt;div class="fb-loop-back" style="margin-top:1rem;"&gt;
        🔁 불통과 시: feedback.md에 기록 → Writer가 피드백 기반으로 프롬프트 수정 → 재생성 → 다시 Evaluator
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class="highlight" style="margin-top:2rem;"&gt;
      &lt;h4&gt;⚠️ self-bias 보정 데이터 (Addy Osmani 하네스)&lt;/h4&gt;
      &lt;p&gt;Claude 자기 채점: 9.04 / 독립 평가: 7.43 → 1.6점 차이. 같은 글을 자기가 쓰면 후하게 봅니다. 그래서 &lt;strong&gt;반드시 독립 Evaluator/Critic를 분리&lt;/strong&gt;합니다.&lt;/p&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 6. EVOLUTION — —&gt;
&lt;section id="evolution"&gt;
  &lt;h2&gt;📈 진화 구조 — 버전이 누적되면서 학습&lt;/h2&gt;
  &lt;p class="desc"&gt;
    매 루프마다 생성된 산출물, 피드백, 평가 점수가 상태 파일에 누적됩니다. 프로젝트가 끝나면 이 진화 기록이 SKILL.md에 반영되어 다음 프로젝트의 기준이 됩니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;EVOLUTION TIMELINE — 진화가 누적되는 구조&lt;/div&gt;
    &lt;svg viewBox="0 0 900 300" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;"&gt;
      &lt;!— — Timeline Base — —&gt;
      &lt;line x1="50" y1="150" x2="850" y2="150" stroke="#334155" stroke-width="2"/&gt;

      &lt;!— — v1 — —&gt;
      &lt;circle cx="150" cy="150" r="25" fill="#1e293b" stroke="#6366f1" stroke-width="2"/&gt;
      &lt;text x="150" y="155" text-anchor="middle" fill="#818cf8" font-size="11" font-weight="700"&gt;v1&lt;/text&gt;
      &lt;text x="150" y="195" text-anchor="middle" fill="#94a3b8" font-size="9"&gt;초안 생성&lt;/text&gt;
      &lt;text x="150" y="210" text-anchor="middle" fill="#64748b" font-size="8"&gt;Evaluator: 6.5&lt;/text&gt;
      &lt;!— — v1 output — —&gt;
      &lt;rect x="115" y="80" width="70" height="35" rx="6" fill="#1e293b" stroke="#334155" stroke-width="1"/&gt;
      &lt;text x="150" y="100" text-anchor="middle" fill="#64748b" font-size="8"&gt;28컷&lt;/text&gt;

      &lt;!— — Arrow — —&gt;
      &lt;line x1="175" y1="150" x2="275" y2="150" stroke="#ef4444" stroke-width="1.5" marker-end="url(#arrowRed2)"/&gt;
      &lt;text x="225" y="140" text-anchor="middle" fill="#ef4444" font-size="8"&gt;feedback.md&lt;/text&gt;

      &lt;!— — v2 — —&gt;
      &lt;circle cx="300" cy="150" r="25" fill="#1e293b" stroke="#06b6d4" stroke-width="2"/&gt;
      &lt;text x="300" y="155" text-anchor="middle" fill="#06b6d4" font-size="11" font-weight="700"&gt;v2&lt;/text&gt;
      &lt;text x="300" y="195" text-anchor="middle" fill="#94a3b8" font-size="9"&gt;색감 수정&lt;/text&gt;
      &lt;text x="300" y="210" text-anchor="middle" fill="#64748b" font-size="8"&gt;Evaluator: 7.8&lt;/text&gt;
      &lt;rect x="265" y="80" width="70" height="35" rx="6" fill="#1e293b" stroke="#334155" stroke-width="1"/&gt;
      &lt;text x="300" y="100" text-anchor="middle" fill="#64748b" font-size="8"&gt;28컷&lt;/text&gt;

      &lt;!— — Arrow — —&gt;
      &lt;line x1="325" y1="150" x2="425" y2="150" stroke="#ef4444" stroke-width="1.5" marker-end="url(#arrowRed2)"/&gt;
      &lt;text x="375" y="140" text-anchor="middle" fill="#ef4444" font-size="8"&gt;feedback.md&lt;/text&gt;

      &lt;!— — v3 — —&gt;
      &lt;circle cx="450" cy="150" r="25" fill="#1e293b" stroke="#22c55e" stroke-width="2"/&gt;
      &lt;text x="450" y="155" text-anchor="middle" fill="#22c55e" font-size="11" font-weight="700"&gt;v3&lt;/text&gt;
      &lt;text x="450" y="195" text-anchor="middle" fill="#94a3b8" font-size="9"&gt;일관성 보정&lt;/text&gt;
      &lt;text x="450" y="210" text-anchor="middle" fill="#64748b" font-size="8"&gt;Evaluator: 8.5&lt;/text&gt;
      &lt;rect x="415" y="80" width="70" height="35" rx="6" fill="#1e293b" stroke="#334155" stroke-width="1"/&gt;
      &lt;text x="450" y="100" text-anchor="middle" fill="#64748b" font-size="8"&gt;28컷&lt;/text&gt;

      &lt;!— — Approved — —&gt;
      &lt;line x1="475" y1="150" x2="575" y2="150" stroke="#22c55e" stroke-width="2" marker-end="url(#arrowGreen2)"/&gt;
      &lt;text x="525" y="135" text-anchor="middle" fill="#22c55e" font-size="9" font-weight="600"&gt;✅ 승인&lt;/text&gt;

      &lt;!— — Final — —&gt;
      &lt;rect x="575" y="120" width="120" height="60" rx="12" fill="#1e293b" stroke="#22c55e" stroke-width="2"/&gt;
      &lt;text x="635" y="148" text-anchor="middle" fill="#22c55e" font-size="12" font-weight="700"&gt;📦 final&lt;/text&gt;
      &lt;text x="635" y="166" text-anchor="middle" fill="#94a3b8" font-size="9"&gt;28컷 완성&lt;/text&gt;

      &lt;!— — Evolution Log — —&gt;
      &lt;rect x="575" y="200" width="250" height="80" rx="10" fill="#1e293b" stroke="#f59e0b" stroke-width="1.5"/&gt;
      &lt;text x="700" y="220" text-anchor="middle" fill="#f59e0b" font-size="10" font-weight="600"&gt;evolution.md&lt;/text&gt;
      &lt;text x="590" y="240" fill="#94a3b8" font-size="8"&gt;• v1→v2: 색감 feedback 반영 (+1.3점)&lt;/text&gt;
      &lt;text x="590" y="255" fill="#94a3b8" font-size="8"&gt;• v2→v3: 캐릭터 일관성 보정 (+0.7점)&lt;/text&gt;
      &lt;text x="590" y="270" fill="#94a3b8" font-size="8"&gt;• 학습 패턴 → SKILL.md 업데이트&lt;/text&gt;

      &lt;!— — Next Project — —&gt;
      &lt;line x1="695" y1="280" x2="695" y2="250" stroke="#f59e0b" stroke-width="1.5" marker-end="url(#arrowAmber)"/&gt;
      &lt;text x="810" y="220" fill="#f59e0b" font-size="9" font-weight="600"&gt;→ 다음 프로젝트에 적용&lt;/text&gt;

      &lt;defs&gt;
        &lt;marker id="arrowRed2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#ef4444"/&gt;
        &lt;/marker&gt;
        &lt;marker id="arrowGreen2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#22c55e"/&gt;
        &lt;/marker&gt;
        &lt;marker id="arrowAmber" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto"&gt;
          &lt;path d="M 0 0 L 10 5 L 0 10 z" fill="#f59e0b"/&gt;
        &lt;/marker&gt;
      &lt;/defs&gt;
    &lt;/svg&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 7. EXAMPLE: Three Body — —&gt;
&lt;section id="example"&gt;
  &lt;h2&gt;🌌 삼체 만화 EP001에 적용&lt;/h2&gt;
  &lt;p class="desc"&gt;
    기존에 수동으로 진행된 삼체 만화 제작 과정을 이 Creative Loop에 맞춰 재구조화합니다.
  &lt;/p&gt;

  &lt;div class="diagram"&gt;
    &lt;div class="diagram-title"&gt;THREE BODY COMIC — 적용 예시&lt;/div&gt;

    &lt;div class="code"&gt;
&lt;span class="comment"&gt;// Phase 1: DEFINE — 주인님 입력 → PRD 자동 생성&lt;/span&gt;
{
  &lt;span class="key"&gt;"project"&lt;/span&gt;: &lt;span class="val"&gt;"삼체 만화 EP001"&lt;/span&gt;,
  &lt;span class="key"&gt;"theme"&lt;/span&gt;: &lt;span class="val"&gt;"문화대혁명 시절의 밤, 과학자들의 선택"&lt;/span&gt;,
  &lt;span class="key"&gt;"style"&lt;/span&gt;: &lt;span class="val"&gt;"수채화풍, 웹툰 컷 구성"&lt;/span&gt;,
  &lt;span class="key"&gt;"mood"&lt;/span&gt;: &lt;span class="val"&gt;"긴장감, 미스터리, 클리프행거"&lt;/span&gt;,
  &lt;span class="key"&gt;"format"&lt;/span&gt;: &lt;span class="val"&gt;"28페이지, 81패널"&lt;/span&gt;,
  &lt;span class="key"&gt;"characters"&lt;/span&gt;: [&lt;span class="val"&gt;"장베이하이"&lt;/span&gt;, &lt;span class="val"&gt;"왕먀오"&lt;/span&gt;, &lt;span class="val"&gt;"스치친"&lt;/span&gt;],
  &lt;span class="key"&gt;"reference"&lt;/span&gt;: &lt;span class="val"&gt;"wiki/characters/, PRD v2.1"&lt;/span&gt;
}
    &lt;/div&gt;

    &lt;table class="compare-table"&gt;
      &lt;thead&gt;
        &lt;tr&gt;
          &lt;th&gt;Phase&lt;/th&gt;
          &lt;th&gt;기존 (수동)&lt;/th&gt;
          &lt;th&gt;루프 적용 (자동)&lt;/th&gt;
        &lt;/tr&gt;
      &lt;/thead&gt;
      &lt;tbody&gt;
        &lt;tr&gt;
          &lt;td&gt;&lt;strong style="color:var(— —accent2)"&gt;Define&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;주인님이 PRD 직접 작성&lt;/td&gt;
          &lt;td&gt;주제 선택 → Planner가 PRD 자동 생성 → ✋ 승인&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
          &lt;td&gt;&lt;strong style="color:var(— —cyan)"&gt;Sample&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;화풍 4종 수동 비교&lt;/td&gt;
          &lt;td&gt;Writer가 3화풍 샘플 자동 생성 → ✋ 주인님이 선택&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
          &lt;td&gt;&lt;strong style="color:var(— —green)"&gt;Produce&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;16/28장 수동 생성 후 멈춤&lt;/td&gt;
          &lt;td&gt;전체 28컷 자동 생성 + 중간 체크포인트&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
          &lt;td&gt;&lt;strong style="color:var(— —purple)"&gt;Refine&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;없음 (수정 루프 없었음)&lt;/td&gt;
          &lt;td&gt;Critic 평가 → 피드백 → v2/v3 자동 수정&lt;/td&gt;
        &lt;/tr&gt;
        &lt;tr&gt;
          &lt;td&gt;&lt;strong style="color:var(— —pink)"&gt;Deliver&lt;/strong&gt;&lt;/td&gt;
          &lt;td&gt;미완성 상태로 GitHub Pages&lt;/td&gt;
          &lt;td&gt;최종 산출 + 메타데이터 + 진화 로그&lt;/td&gt;
        &lt;/tr&gt;
      &lt;/tbody&gt;
    &lt;/table&gt;

    &lt;div class="highlight" style="margin-top:1.5rem;"&gt;
      &lt;h4&gt;🎯 핵심 차이&lt;/h4&gt;
      &lt;p&gt;기존: 주인님이 매 단계 직접 지시 → "근데 8장만 생성된거니?" "나머지는?" → 멈춤&lt;br&gt;
      루프 적용: 한 번 설정하면 전체 28컷 자동 생성 + 중간에만 주인님이 확인 → 완성&lt;/p&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 8. COMPARISON — —&gt;
&lt;section id="comparison"&gt;
  &lt;h2&gt;⚖️ 루프 엔지니어링 vs 기존 방식&lt;/h2&gt;
  &lt;p class="desc"&gt;"매번 프롬프트"와 "루프를 설계"의 차이를 구체적으로 비교합니다.&lt;/p&gt;

  &lt;table class="compare-table"&gt;
    &lt;thead&gt;
      &lt;tr&gt;
        &lt;th&gt;관점&lt;/th&gt;
        &lt;th&gt;기존 (프롬프트 엔지니어링)&lt;/th&gt;
        &lt;th&gt;루프 엔지니어링&lt;/th&gt;
      &lt;/tr&gt;
    &lt;/thead&gt;
    &lt;tbody&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;역할&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;실행자 (매 줄 지시)&lt;/td&gt;
        &lt;td&gt;감독관 (시스템 설계)&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;재사용&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;프롬프트 복붙&lt;/td&gt;
        &lt;td&gt;SKILL.md + 상태 파일 (프로젝트 간)&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;품질 검증&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;주인님 눈으로만&lt;/td&gt;
        &lt;td&gt;서브에이전트 독립 평가 + 주인님 최종 승인&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;피드백&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;대화 중 구두로&lt;/td&gt;
        &lt;td&gt;게이트에서 구조화된 피드백 (기록됨)&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;진화&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;사람 머릿속에만&lt;/td&gt;
        &lt;td&gt;evolution.md에 기록 → 다음 프로젝트에 적용&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;한계&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;세션 바뀌면 컨텍스트 리셋&lt;/td&gt;
        &lt;td&gt;상태 파일로 컨텍스트 유지&lt;/td&gt;
      &lt;/tr&gt;
      &lt;tr&gt;
        &lt;td&gt;&lt;strong&gt;주의점&lt;/strong&gt;&lt;/td&gt;
        &lt;td&gt;AI 의존도 과대평가&lt;/td&gt;
        &lt;td&gt;인지적 항복 주의 — 검토는 사람 몫&lt;/td&gt;
      &lt;/tr&gt;
    &lt;/tbody&gt;
  &lt;/table&gt;
&lt;/section&gt;

&lt;div class="divider"&gt;&lt;/div&gt;

&lt;!— — 9. IMPLEMENTATION — —&gt;
&lt;section id="implementation"&gt;
  &lt;h2&gt;🚀 구현 계획&lt;/h2&gt;
  &lt;p class="desc"&gt;
    OpenClaw의 기존 스킬 생태계 + 루프 엔지니어링을 통합하여 구현합니다.
  &lt;/p&gt;

  &lt;div class="phases"&gt;
    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:rgba(99,102,241,0.1); border:1px solid var(— —accent);"&gt;
        &lt;span class="num" style="color:var(— —accent2);font-size:1.5rem;"&gt;S1&lt;/span&gt;
        &lt;span class="name" style="color:var(— —accent2);font-size:0.6rem;"&gt;스킬&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content"&gt;
        &lt;h4&gt;SKILL.md 작성&lt;/h4&gt;
        &lt;p&gt;Creative Loop SKILL.md에 프로젝트 인수인계 노트를 작성합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;Phase별 입력/출력 스펙 정의&lt;/li&gt;
          &lt;li&gt;프롬프트 템플릿 라이브러리&lt;/li&gt;
          &lt;li&gt;품질 평가 체크리스트&lt;/li&gt;
          &lt;li&gt;진화 메타데이터 스키마&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:rgba(6,182,212,0.1); border:1px solid var(— —cyan);"&gt;
        &lt;span class="num" style="color:var(— —cyan);font-size:1.5rem;"&gt;S2&lt;/span&gt;
        &lt;span class="name" style="color:var(— —cyan);font-size:0.6rem;"&gt;에이전트&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content"&gt;
        &lt;h4&gt;서브에이전트 구성&lt;/h4&gt;
        &lt;p&gt;Writer/Evaluator/Critic/Planner를 서브에이전트로 분리합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;Writer: 프롬프트 생성 + 이미지 API 호출&lt;/li&gt;
          &lt;li&gt;Evaluator: 일관성/품질 자동 평가 (별도 세션)&lt;/li&gt;
          &lt;li&gt;Critic: 비판적 분석 + 개선 제안 (별도 세션)&lt;/li&gt;
          &lt;li&gt;Planner: Phase 오케스트레이션 + 게이트 관리&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:rgba(34,197,94,0.1); border:1px solid var(— —green);"&gt;
        &lt;span class="num" style="color:var(— —green);font-size:1.5rem;"&gt;S3&lt;/span&gt;
        &lt;span class="name" style="color:var(— —green);font-size:0.6rem;"&gt;상태&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content"&gt;
        &lt;h4&gt;상태 파일 시스템&lt;/h4&gt;
        &lt;p&gt;프로젝트 진행 상태를 디스크에 지속적으로 기록합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;config.json: 주인님 설정&lt;/li&gt;
          &lt;li&gt;progress.md: 현재 Phase + 완료된 컷&lt;/li&gt;
          &lt;li&gt;feedback.md: 피드백 기록&lt;/li&gt;
          &lt;li&gt;evolution.md: 버전별 변경 이력&lt;/li&gt;
          &lt;li&gt;scores.json: Evaluator/Critic 점수 추이&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/div&gt;
    &lt;/div&gt;

    &lt;div class="phase"&gt;
      &lt;div class="phase-badge" style="background:rgba(236,72,153,0.1); border:1px solid var(— —pink);"&gt;
        &lt;span class="num" style="color:var(— —pink);font-size:1.5rem;"&gt;S4&lt;/span&gt;
        &lt;span class="name" style="color:var(— —pink);font-size:0.6rem;"&gt;검증&lt;/span&gt;
      &lt;/div&gt;
      &lt;div class="phase-content"&gt;
        &lt;h4&gt;삼체 EP001로 검증&lt;/h4&gt;
        &lt;p&gt;실제 프로젝트에 적용하여 시스템을 검증합니다.&lt;/p&gt;
        &lt;ul&gt;
          &lt;li&gt;EP001 나머지 12컷을 루프로 자동 생성&lt;/li&gt;
          &lt;li&gt;중간 피드백 게이트 실제 테스트&lt;/li&gt;
          &lt;li&gt;v1→v2 진화 루프 실증&lt;/li&gt;
          &lt;li&gt;학습 패턴이 SKILL.md에 자동 누적되는지 확인&lt;/li&gt;
        &lt;/ul&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;

  &lt;div class="highlight" style="margin-top:2rem;"&gt;
    &lt;h4&gt;📝 최종 목표&lt;/h4&gt;
    &lt;p&gt;"주제: 해적, 화풍: 3D 애니, 분위기: 모험" 한 줄이면 → 샘플 확인 → 자동 전체 생성 → 피드백 루프 → 완성 산출물. 주인님은 감독관 역할만 하시면 됩니다.&lt;/p&gt;
  &lt;/div&gt;
&lt;/section&gt;

&lt;footer&gt;
  &lt;p&gt;창의적 루프 엔지니어링 시스템 설계 문서 — 2026.06.16&lt;/p&gt;
  &lt;p&gt;기반: Addy Osmani "Loop Engineering" + OpenClaw Skill Ecosystem + 랄프톤 Phase Split&lt;/p&gt;
  &lt;p style="margin-top:0.5rem; color:#64748b;"&gt;"Build the loop. But build it like someone who intends to stay the engineer."&lt;/p&gt;
&lt;/footer&gt;

&lt;script&gt;
// Smooth scroll
document.querySelectorAll('.nav a').forEach(a =&gt; {
  a.addEventListener('click', e =&gt; {
    e.preventDefault();
    const target = document.querySelector(a.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});

// Active nav highlight
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav a');

window.addEventListener('scroll', () =&gt; {
  let current = '';
  sections.forEach(section =&gt; {
    const top = section.offsetTop - 100;
    if (pageYOffset &gt;= top) current = section.getAttribute('id');
  });
  navLinks.forEach(link =&gt; {
    link.classList.remove('active');
    if (link.getAttribute('href') === `#${current}`) link.classList.add('active');
  });
});
&lt;/script&gt;

&lt;/body&gt;
&lt;/html&gt;

-->
<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Creative Loop Engine v1.0</title>
<style>
:root {
  --bg: #0a0e17;
  --surface: #111827;
  --surface2: #1a2235;
  --surface3: #23304b;
  --border: #1e293b;
  --text: #e2e8f0;
  --text2: #94a3b8;
  --accent: #6366f1;
  --accent2: #818cf8;
  --green: #22c55e;
  --amber: #f59e0b;
  --red: #ef4444;
  --blue: #3b82f6;
  --purple: #a855f7;
  --teal: #14b8a6;
  --shadow: 0 20px 45px rgba(0, 0, 0, 0.28);
  --glow: 0 0 0 1px rgba(99, 102, 241, 0.35), 0 0 28px rgba(99, 102, 241, 0.2);
  --radius: 18px;
  --speed: 0.3s ease;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  background:
    radial-gradient(circle at top, rgba(99, 102, 241, 0.22), transparent 30%),
    radial-gradient(circle at 85% 20%, rgba(20, 184, 166, 0.16), transparent 25%),
    linear-gradient(180deg, #09101b 0%, #0a0e17 38%, #070b12 100%);
  color: var(--text);
  font-family: "Segoe UI", "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
  min-height: 100vh;
}
a { color: inherit; text-decoration: none; }
button, input, textarea, select { font: inherit; }
button {
  cursor: pointer;
  border: 0;
  transition: transform var(--speed), box-shadow var(--speed), background var(--speed), border-color var(--speed), color var(--speed), opacity var(--speed);
}
img { max-width: 100%; display: block; }
.shell {
  min-height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr auto;
}
.app-header {
  position: sticky;
  top: 0;
  z-index: 50;
  backdrop-filter: blur(18px);
  background: rgba(10, 14, 23, 0.84);
  border-bottom: 1px solid rgba(148, 163, 184, 0.14);
}
.topbar {
  width: min(1180px, calc(100% - 24px));
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 14px 0;
}
.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  font-weight: 800;
  letter-spacing: 0.02em;
}
.brand-badge {
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background: linear-gradient(135deg, rgba(99,102,241,0.25), rgba(20,184,166,0.3));
  border: 1px solid rgba(129, 140, 248, 0.4);
  box-shadow: var(--glow);
}
.nav-row {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  justify-content: center;
  flex-wrap: wrap;
}
.nav-link {
  color: var(--text2);
  padding: 10px 14px;
  border-radius: 999px;
  font-size: 0.93rem;
}
.nav-link:hover, .nav-link.active {
  background: rgba(99, 102, 241, 0.16);
  color: var(--text);
}
.ghost-btn, .primary-btn, .secondary-btn, .danger-btn {
  border-radius: 14px;
  padding: 12px 16px;
}
.ghost-btn {
  background: transparent;
  border: 1px solid rgba(148, 163, 184, 0.24);
  color: var(--text);
}
.ghost-btn:hover, .secondary-btn:hover, .primary-btn:hover, .danger-btn:hover {
  transform: translateY(-1px) scale(1.01);
}
.primary-btn {
  background: linear-gradient(135deg, var(--accent), var(--teal));
  color: white;
  box-shadow: 0 14px 34px rgba(99, 102, 241, 0.28);
}
.secondary-btn {
  background: rgba(99, 102, 241, 0.14);
  color: var(--accent2);
  border: 1px solid rgba(99, 102, 241, 0.28);
}
.danger-btn {
  background: rgba(239, 68, 68, 0.12);
  color: #fecaca;
  border: 1px solid rgba(239, 68, 68, 0.25);
}
main {
  width: min(1180px, calc(100% - 24px));
  margin: 0 auto;
  padding: 26px 0 100px;
}
.route-view {
  opacity: 0;
  transform: translateY(18px);
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.route-view.is-ready {
  opacity: 1;
  transform: translateY(0);
}
.page {
  display: grid;
  gap: 22px;
}
.panel, .hero-card, .wizard-card, .gallery-card, .project-card, .status-panel, .settings-card, .modal-card {
  background: linear-gradient(180deg, rgba(17, 24, 39, 0.94), rgba(11, 17, 29, 0.98));
  border: 1px solid rgba(148, 163, 184, 0.12);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
}
.page-title {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12px;
  flex-wrap: wrap;
}
.page-title h1, .page-title h2, .hero-copy h1 {
  margin: 0;
  font-size: clamp(2rem, 4vw, 3.9rem);
  line-height: 1.05;
}
.page-title p, .hero-copy p, .muted {
  color: var(--text2);
}
.hero-card {
  position: relative;
  overflow: hidden;
  padding: 28px;
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 24px;
  align-items: center;
}
.hero-card::before {
  content: "";
  position: absolute;
  inset: -20% 50% auto -10%;
  height: 320px;
  background: radial-gradient(circle, rgba(99, 102, 241, 0.28), transparent 58%);
  pointer-events: none;
}
.hero-copy {
  display: grid;
  gap: 16px;
}
.eyebrow {
  display: inline-flex;
  gap: 8px;
  align-items: center;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(20, 184, 166, 0.14);
  color: #99f6e4;
  font-size: 0.88rem;
  width: fit-content;
}
.hero-actions, .stack-row, .wrap-row {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  align-items: center;
}
.tags { display: flex; gap: 10px; flex-wrap: wrap; }
.tag {
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(148,163,184,0.1);
  color: var(--text2);
  border: 1px solid rgba(148,163,184,0.12);
  font-size: 0.88rem;
}
.loop-visual {
  position: relative;
  aspect-ratio: 1;
  max-width: 420px;
  margin: 0 auto;
}
.loop-ring {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 0 30px rgba(99,102,241,0.18));
}
.loop-node text { fill: var(--text); font-size: 12px; font-weight: 700; }
.orbit-dot { animation: orbit 12s linear infinite; transform-origin: 50% 50%; }
@keyframes orbit { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes pulse { 0%,100% { opacity: 0.5; transform: scale(0.96); } 50% { opacity: 1; transform: scale(1.04); } }
@keyframes pulseFast { 0%,100% { opacity: 0.45; } 50% { opacity: 1; } }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
@keyframes shake { 0%,100% { transform: translateX(0); } 20% { transform: translateX(-3px); } 40% { transform: translateX(3px); } 60% { transform: translateX(-2px); } 80% { transform: translateX(2px); } }
@keyframes blink { 0%,49% { opacity: 1; } 50%,100% { opacity: 0.3; } }
.status-icon.spin { display: inline-block; animation: spin 1.2s linear infinite; }
.status-icon.pulse { display: inline-block; animation: pulse 1.8s ease infinite; }
.status-icon.fade { display: inline-block; animation: fadeIn 0.4s ease both; }
.status-icon.shake { display: inline-block; animation: shake 0.45s ease; }
.status-icon.blink { display: inline-block; animation: blink 1s step-end infinite; }
.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.section-head h3, .section-head h2, .stack-title h3 {
  margin: 0;
  font-size: 1.2rem;
}
.gallery-strip {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}
.thumb-card, .candidate-card {
  overflow: hidden;
  border-radius: 16px;
  border: 1px solid rgba(148,163,184,0.12);
  background: rgba(17, 24, 39, 0.86);
  transition: transform var(--speed), border-color var(--speed), box-shadow var(--speed);
}
.thumb-card:hover, .select-card:hover, .project-card:hover, .gallery-card:hover, .candidate-card:hover {
  transform: scale(1.02);
  border-color: rgba(129, 140, 248, 0.45);
  box-shadow: 0 18px 34px rgba(15, 23, 42, 0.4);
}
.thumb-visual, .gallery-visual, .candidate-visual, .project-visual, .modal-visual {
  min-height: 140px;
  background-size: cover;
  background-position: center;
}
.thumb-content, .project-content, .gallery-content {
  padding: 14px;
  display: grid;
  gap: 10px;
}
.tutorial {
  position: fixed;
  right: 16px;
  bottom: 90px;
  z-index: 60;
  width: min(360px, calc(100vw - 32px));
  padding: 18px;
  background: linear-gradient(180deg, rgba(17,24,39,0.98), rgba(9,14,23,0.98));
  border: 1px solid rgba(129,140,248,0.3);
  border-radius: 20px;
  box-shadow: var(--shadow);
  animation: fadeIn 0.35s ease;
}
.tutorial-dots { display: flex; gap: 8px; }
.tutorial-dot {
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: rgba(148,163,184,0.24);
}
.tutorial-dot.active { background: var(--accent2); }
.wizard-layout {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 20px;
}
.wizard-card, .status-panel, .settings-card {
  padding: 22px;
}
.step-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  color: var(--accent2);
  background: rgba(99,102,241,0.14);
  padding: 8px 12px;
  border-radius: 999px;
}
.step-track {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}
.step-bar {
  height: 6px;
  border-radius: 999px;
  background: rgba(148,163,184,0.12);
  overflow: hidden;
}
.step-bar span {
  display: block;
  height: 100%;
  width: 0;
  background: linear-gradient(90deg, var(--accent), var(--teal));
  transition: width var(--speed);
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}
.select-card {
  padding: 16px;
  border-radius: 16px;
  border: 1px solid rgba(148,163,184,0.14);
  background: rgba(17,24,39,0.88);
  display: grid;
  gap: 8px;
  min-height: 118px;
  transition: transform var(--speed), border-color var(--speed), box-shadow var(--speed), background var(--speed);
}
.select-card.active {
  border-color: var(--accent2);
  box-shadow: var(--glow);
  background: linear-gradient(180deg, rgba(99,102,241,0.18), rgba(17,24,39,0.96));
}
.select-card .emoji { font-size: 1.5rem; }
.custom-input, .search-input, textarea, .inline-input, input[type="text"] {
  width: 100%;
  background: rgba(15, 23, 42, 0.7);
  border: 1px solid rgba(148,163,184,0.16);
  color: var(--text);
  border-radius: 14px;
  padding: 12px 14px;
}
.preview-stack {
  display: grid;
  gap: 14px;
}
.preview-card {
  padding: 18px;
  border-radius: 18px;
  background: linear-gradient(135deg, rgba(99,102,241,0.16), rgba(20,184,166,0.12));
  border: 1px solid rgba(129,140,248,0.2);
}
.combo-title { font-size: 1.5rem; font-weight: 800; margin: 0 0 8px; }
.info-bar {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  padding: 14px 16px;
  border-radius: 16px;
  background: rgba(148,163,184,0.08);
  color: var(--text2);
}
.project-hero {
  display: grid;
  gap: 20px;
}
.phase-pipeline {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 6px;
}
.phase-item {
  min-width: 150px;
  padding: 14px;
  border-radius: 18px;
  background: rgba(15,23,42,0.82);
  border: 1px solid rgba(148,163,184,0.12);
  position: relative;
}
.phase-item::after {
  content: "";
  position: absolute;
  top: 24px;
  right: -10px;
  width: 18px;
  height: 2px;
  background: linear-gradient(90deg, currentColor, rgba(148,163,184,0.18));
}
.phase-item:last-child::after { display: none; }
.phase-item.active { box-shadow: var(--glow); }
.phase-item.complete { border-color: rgba(34,197,94,0.35); }
.phase-item.pending { opacity: 0.82; }
.phase-item .phase-num { font-size: 0.8rem; color: var(--text2); }
.phase-item .phase-name { font-size: 1rem; font-weight: 700; margin-top: 8px; }
.phase-item .phase-status { font-size: 0.88rem; margin-top: 10px; display: flex; gap: 8px; align-items: center; }
.project-layout {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 20px;
}
.candidate-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}
.candidate-card { position: relative; }
.candidate-card .candidate-visual {
  min-height: 170px;
  display: grid;
  place-items: center;
  font-weight: 800;
  font-size: 1.3rem;
}
.candidate-meta { padding: 14px; display: grid; gap: 8px; }
.retry-btn { width: 100%; }
.status-panel { display: grid; gap: 16px; }
.status-banner {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(148,163,184,0.14);
}
.feedback-chip {
  display: inline-flex;
  padding: 0.4rem 0.8rem;
  border-radius: 20px;
  background: var(--surface2);
  border: 1px solid var(--border);
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.2s;
}
.feedback-chip:hover { border-color: var(--accent); }
.feedback-chip.selected {
  background: rgba(99,102,241,0.15);
  border-color: var(--accent);
  color: var(--accent2);
}
.feedback-grid { display: flex; gap: 10px; flex-wrap: wrap; }
.slider-row {
  display: grid;
  grid-template-columns: 92px 1fr auto;
  gap: 10px;
  align-items: center;
}
.slider-row input[type="range"] { width: 100%; }
.recovery-box, .privacy-box, .empty-state {
  padding: 16px;
  border-radius: 16px;
  background: rgba(148,163,184,0.08);
  border: 1px solid rgba(148,163,184,0.12);
}
.radio-group {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.radio-card {
  flex: 1 1 140px;
  border: 1px solid rgba(148,163,184,0.14);
  border-radius: 16px;
  padding: 14px;
  background: rgba(15,23,42,0.72);
}
.radio-card.active { border-color: rgba(129,140,248,0.38); box-shadow: var(--glow); }
.project-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}
.project-card { overflow: hidden; }
.project-visual { min-height: 160px; }
.progress-mini {
  height: 8px;
  border-radius: 999px;
  background: rgba(148,163,184,0.12);
  overflow: hidden;
}
.progress-mini span {
  display: block;
  height: 100%;
  background: linear-gradient(90deg, var(--accent), var(--teal));
}
.filter-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  align-items: center;
}
.filter-chip {
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(148,163,184,0.08);
  border: 1px solid rgba(148,163,184,0.14);
  color: var(--text2);
}
.filter-chip.active { color: var(--text); border-color: rgba(129,140,248,0.42); background: rgba(99,102,241,0.16); }
.masonry { column-count: 3; column-gap: 14px; }
.gallery-card {
  display: inline-block;
  width: 100%;
  margin: 0 0 14px;
  overflow: hidden;
}
.gallery-content { padding: 14px; }
.meta-line {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  color: var(--text2);
  font-size: 0.88rem;
}
.settings-list { display: grid; gap: 14px; }
.disabled-pill {
  display: inline-flex;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(148,163,184,0.1);
  color: var(--text2);
}
.footer {
  width: min(1180px, calc(100% - 24px));
  margin: 0 auto;
  padding: 20px 0 28px;
  color: var(--text2);
  border-top: 1px solid rgba(148,163,184,0.12);
  text-align: center;
}
.bottom-nav {
  position: fixed;
  left: 12px;
  right: 12px;
  bottom: 12px;
  z-index: 40;
  display: none;
  gap: 8px;
  padding: 10px;
  border-radius: 20px;
  background: rgba(10,14,23,0.92);
  border: 1px solid rgba(148,163,184,0.14);
  backdrop-filter: blur(12px);
}
.bottom-nav a {
  flex: 1;
  padding: 10px 8px;
  border-radius: 14px;
  text-align: center;
  font-size: 0.8rem;
  color: var(--text2);
}
.bottom-nav a.active { background: rgba(99,102,241,0.18); color: var(--text); }
.modal {
  position: fixed;
  inset: 0;
  background: rgba(2, 6, 23, 0.76);
  display: none;
  align-items: center;
  justify-content: center;
  padding: 18px;
  z-index: 80;
}
.modal.open { display: flex; }
.modal-card {
  width: min(720px, 100%);
  padding: 22px;
  display: grid;
  gap: 16px;
}
.modal-visual { min-height: 280px; border-radius: 16px; }
.scroll-reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}
.scroll-reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
@media (max-width: 960px) {
  .hero-grid, .wizard-layout, .project-layout { grid-template-columns: 1fr; }
  .gallery-strip, .project-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 720px) {
  .nav-row { display: none; }
  .topbar { padding: 12px 0; }
  main { padding-bottom: 120px; }
  .gallery-strip, .candidate-grid, .project-grid, .card-grid { grid-template-columns: 1fr; }
  .masonry { column-count: 1; }
  .phase-pipeline { grid-template-columns: repeat(5, minmax(150px, 1fr)); }
  .bottom-nav { display: grid; grid-template-columns: repeat(5, 1fr); }
}
</style>
</head>
<body>
<div class="shell">
  <header class="app-header">
    <div class="topbar">
      <a class="brand" href="#/landing" aria-label="Creative Loop 홈">
        <span class="brand-badge">🔁</span>
        <span>Creative Loop Engine</span>
      </a>
      <nav class="nav-row" id="topNav"></nav>
      <button class="ghost-btn" type="button" id="githubPlaceholder">GitHub 로그인 · Phase 2</button>
    </div>
  </header>
  <main>
    <div id="app" class="route-view"></div>
  </main>
  <footer class="footer">Creative Loop Engine v1.0</footer>
</div>
<nav class="bottom-nav" id="bottomNav"></nav>
<div id="tutorialRoot"></div>
<div class="modal" id="galleryModal" aria-hidden="true"></div>
<script>
const STORAGE_KEYS = { projects: 'cle_projects', settings: 'cle_settings' };
const SESSION_KEYS = { projectId: 'cle_current_project', wizard: 'cle_wizard_draft' };
const NAV_ITEMS = [
  { label: '랜딩', path: '/landing', icon: '🏠' },
  { label: '새 프로젝트', path: '/new', icon: '✨' },
  { label: '대시보드', path: '/dashboard', icon: '📁' },
  { label: '갤러리', path: '/gallery', icon: '🖼️' },
  { label: '설정', path: '/settings', icon: '⚙️' }
];
const PHASES = [
  { key: 'define', label: 'Define', color: 'var(--blue)' },
  { key: 'generate', label: 'Generate', color: 'var(--purple)' },
  { key: 'evaluate', label: 'Evaluate', color: 'var(--amber)' },
  { key: 'refine', label: 'Refine', color: 'var(--green)' },
  { key: 'deliver', label: 'Deliver', color: 'var(--teal)' }
];
const STATUS_META = {
  idle: { icon: '⏳', color: 'var(--text2)', anim: 'pulse', text: '대기 중' },
  generating: { icon: '🔄', color: 'var(--accent)', anim: 'spin', text: '생성 중' },
  partial_fail: { icon: '⚠️', color: 'var(--amber)', anim: 'shake', text: '일부 실패' },
  complete: { icon: '✅', color: 'var(--green)', anim: 'fade', text: '완료' },
  timeout: { icon: '🕐', color: 'var(--amber)', anim: 'pulse', text: '지연' },
  network_error: { icon: '📡', color: 'var(--red)', anim: 'blink', text: '네트워크 오류' },
  failed: { icon: '❌', color: 'var(--red)', anim: 'fade', text: '실패' }
};
const WIZARD_STEPS = [
  {
    key: 'topic',
    title: '주제 선택',
    cards: [
      { id: 'sf', emoji: '🚀', label: 'SF미래', desc: '도시, 우주, 기술 확장' },
      { id: 'fantasy', emoji: '🧙', label: '판타지마법', desc: '주문, 왕국, 신비' },
      { id: 'modern', emoji: '🏙️', label: '현대일상', desc: '현실감 있는 장면' },
      { id: 'history', emoji: '📜', label: '역사', desc: '시대성, 고증, 서사' },
      { id: 'drama', emoji: '🎭', label: '드라마', desc: '감정선 중심 전개' },
      { id: 'custom', emoji: '✏️', label: '커스텀', desc: '직접 입력하기' }
    ]
  },
  {
    key: 'style',
    title: '화풍 선택',
    cards: [
      { id: 'watercolor', emoji: '🎨', label: '수채화', desc: '부드럽고 투명한 질감' },
      { id: 'ink', emoji: '✒️', label: '잉크', desc: '선명한 선과 명암' },
      { id: 'oil', emoji: '🖌️', label: '유화', desc: '두텁고 극적인 붓결' },
      { id: 'digital', emoji: '💻', label: '디지털아트', desc: '현대적이고 또렷함' },
      { id: 'realism', emoji: '📷', label: '사실주의', desc: '현실적인 디테일' },
      { id: 'pop', emoji: '🎭', label: '팝아트', desc: '강한 색 대비와 리듬' }
    ]
  },
  {
    key: 'mood',
    title: '분위기 선택',
    cards: [
      { id: 'warm', emoji: '🌅', label: '밝고따뜻함', desc: '포근한 톤과 희망' },
      { id: 'mystery', emoji: '🌙', label: '어둡고미스터리', desc: '심도 있는 긴장감' },
      { id: 'dynamic', emoji: '⚡', label: '역동적', desc: '움직임과 속도감' },
      { id: 'calm', emoji: '🌿', label: '차분하고편안함', desc: '정적인 몰입감' },
      { id: 'bold', emoji: '🔥', label: '강렬하고대담함', desc: '대비와 임팩트' },
      { id: 'dreamy', emoji: '✨', label: '몽환적', desc: '부유하는 감정선' }
    ]
  }
];
const FEEDBACK_CHIPS = ['색감 더 강하게', '캐릭터 유지', '배경 단순화', '텍스트 더 적게', '구도 유지', '더 밝게'];
const TUTORIAL_SLIDES = [
  { title: '1단계 카드 선택', desc: '주제, 화풍, 분위기를 카드로 골라 조합을 만듭니다.' },
  { title: '4개 후보 생성', desc: '프로젝트가 시작되면 4개의 후보 슬롯이 순차적으로 채워집니다.' },
  { title: '피드백 루프', desc: '칩, 별점, 코멘트로 방향을 다듬고 승인하거나 재생성합니다.' }
];
const GALLERY_ITEMS = [
  makeGalleryItem('g1', 'SF 수채화 만화', '만화', '수채화', '최신', 42),
  makeGalleryItem('g2', '현대 팝아트 포스터', '일러스트', '팝아트', '인기', 28),
  makeGalleryItem('g3', '판타지 스토리보드', '스토리보드', '잉크', '최신', 35),
  makeGalleryItem('g4', '드라마 씬 라이팅', '글쓰기', '디지털아트', '인기', 19),
  makeGalleryItem('g5', '역사 다큐 콘셉트', '일러스트', '사실주의', '최신', 25),
  makeGalleryItem('g6', '몽환적 도시 연작', '만화', '유화', '인기', 31)
];
const state = {
  route: '/landing',
  params: {},
  wizardStep: 0,
  modalItem: null,
  galleryFilter: '전체',
  dashboardFilter: '전체',
  gallerySearch: ''
};
function makeGalleryItem(id, title, category, style, sort, likes) {
  return { id, title, category, style, sort, likes, mood: ['따뜻함','미스터리','역동적'][likes % 3], gradient: gradientForSeed(id + title) };
}
function uid() { return 'p_' + Math.random().toString(36).slice(2, 9); }
function token() { return Math.random().toString(36).slice(2, 10); }
function now() { return Date.now(); }
function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, char => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
}
function storageRead(key, fallback) {
  try {
    const value = localStorage.getItem(key);
    return value ? JSON.parse(value) : fallback;
  } catch {
    return fallback;
  }
}
function storageWrite(key, value) {
  localStorage.setItem(key, JSON.stringify(value));
}
function getSettings() {
  const settings = storageRead(STORAGE_KEYS.settings, { theme: 'dark', tutorial_seen: false, language: 'ko' });
  if (!settings.theme) settings.theme = 'dark';
  if (typeof settings.tutorial_seen !== 'boolean') settings.tutorial_seen = false;
  settings.language = 'ko';
  return settings;
}
function saveSettings(next) { storageWrite(STORAGE_KEYS.settings, next); }
function getProjects() { return storageRead(STORAGE_KEYS.projects, []); }
function saveProjects(projects) { storageWrite(STORAGE_KEYS.projects, projects); }
function updateProject(projectId, updater) {
  const projects = getProjects();
  const index = projects.findIndex(project => project.id === projectId);
  if (index === -1) return null;
  const updated = updater(structuredClone(projects[index]));
  projects[index] = updated;
  saveProjects(projects);
  return updated;
}
function structuredClone(value) { return JSON.parse(JSON.stringify(value)); }
function getWizardDraft() {
  try {
    const parsed = JSON.parse(sessionStorage.getItem(SESSION_KEYS.wizard) || 'null');
    return parsed || { topic: [], style: [], mood: [], custom: '' };
  } catch {
    return { topic: [], style: [], mood: [], custom: '' };
  }
}
function saveWizardDraft(draft) { sessionStorage.setItem(SESSION_KEYS.wizard, JSON.stringify(draft)); }
function resetWizardDraft() { saveWizardDraft({ topic: [], style: [], mood: [], custom: '' }); }
function labelFor(stepKey, id) {
  const step = WIZARD_STEPS.find(item => item.key === stepKey);
  const card = step.cards.find(item => item.id === id);
  return card ? card.label : id;
}
function createDefaultPhases() {
  return {
    define: { status: 'complete', timestamp: now() - 5000 },
    generate: { status: 'generating', candidates: Array.from({ length: 4 }, (_, index) => ({ id: 'c' + (index + 1), status: index === 0 ? 'generating' : 'idle', label: '후보 ' + (index + 1) })), timestamp: now() },
    evaluate: { status: 'idle' },
    refine: { status: 'idle' },
    deliver: { status: 'idle' }
  };
}
function buildTitle(draft) {
  const topicLabel = draft.topic[0] ? labelFor('topic', draft.topic[0]) : (draft.custom || '커스텀');
  const styleLabel = draft.style[0] ? labelFor('style', draft.style[0]) : '기본 화풍';
  const categoryLabel = draft.mood[0] ? labelFor('mood', draft.mood[0]) : '프로젝트';
  return [topicLabel.replace('SF미래', 'SF').replace('판타지마법', '판타지'), styleLabel, categoryLabel.includes('따뜻') || categoryLabel.includes('미스터리') ? '만화' : '작업'].join(' ');
}
function createProjectFromDraft(draft) {
  const id = uid();
  const project = {
    id,
    title: buildTitle(draft),
    topic: draft.topic.length ? draft.topic : (draft.custom ? ['custom'] : []),
    style: draft.style,
    mood: draft.mood,
    customTopic: draft.custom,
    phases: createDefaultPhases(),
    feedback: { chips: [], rating_direction: 3, rating_quality: 4, comment: '' },
    privacy: 'private',
    created: now(),
    modified: now(),
    recoveryToken: token(),
    statusState: 'generating',
    progressText: '후보를 준비하고 있습니다',
    etaText: '~2분',
    galleryGradient: gradientForSeed(id),
    lastSimulationAt: now(),
    simulationStep: 0
  };
  const projects = getProjects();
  projects.unshift(project);
  saveProjects(projects);
  sessionStorage.setItem(SESSION_KEYS.projectId, id);
  return project;
}
function gradientForSeed(seed) {
  let hash = 0;
  const source = String(seed);
  for (let i = 0; i < source.length; i++) hash = source.charCodeAt(i) + ((hash << 5) - hash);
  const hueA = Math.abs(hash) % 360;
  const hueB = (hueA + 70) % 360;
  return 'linear-gradient(135deg, hsl(' + hueA + ' 68% 42%), hsl(' + hueB + ' 64% 28%))';
}
function formatDate(ts) {
  return new Date(ts).toLocaleString('ko-KR', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}
function routeTo(path) { location.hash = '#' + path; }
function parseHash() {
  const hash = location.hash.replace(/^#/, '') || '/landing';
  const clean = hash === '/' ? '/landing' : hash;
  const resumeMatch = clean.match(/^\/resume\/([^/]+)$/);
  if (resumeMatch) return { path: '/resume', params: { token: resumeMatch[1] } };
  const projectMatch = clean.match(/^\/project\/([^/]+)$/);
  if (projectMatch) return { path: '/project', params: { id: projectMatch[1] } };
  const known = ['/landing', '/new', '/dashboard', '/gallery', '/settings'];
  return { path: known.includes(clean) ? clean : '/landing', params: {} };
}
function renderNav() {
  const route = state.route;
  const markup = NAV_ITEMS.map(item => {
    const active = route === item.path || (route === '/landing' && item.path === '/landing');
    return '<a class="nav-link ' + (active ? 'active' : '') + '" href="#' + item.path + '">' + item.label + '</a>';
  }).join('');
  document.getElementById('topNav').innerHTML = markup;
  document.getElementById('bottomNav').innerHTML = NAV_ITEMS.map(item => {
    const active = route === item.path || (route === '/landing' && item.path === '/landing');
    return '<a class="' + (active ? 'active' : '') + '" href="#' + item.path + '">' + item.icon + '<br>' + item.label + '</a>';
  }).join('');
}
function statusMarkup(status) {
  const meta = STATUS_META[status] || STATUS_META.idle;
  return '<span class="status-icon ' + meta.anim + '" style="color:' + meta.color + '">' + meta.icon + '</span><span>' + meta.text + '</span>';
}
function overallStatus(project) {
  if (project.statusState) return project.statusState;
  if (project.phases.deliver.status === 'complete') return 'complete';
  if (project.phases.generate.status === 'generating') return 'generating';
  return 'idle';
}
function projectCompletion(project) {
  const completed = PHASES.filter(phase => project.phases[phase.key]?.status === 'complete').length;
  return Math.round((completed / PHASES.length) * 100);
}
function ensureProjectSimulation(projectId) {
  const project = updateProject(projectId, draft => {
    const elapsed = now() - (draft.lastSimulationAt || 0);
    if (draft.phases.deliver.status === 'complete' || elapsed < 3500) return draft;
    draft.lastSimulationAt = now();
    draft.simulationStep = (draft.simulationStep || 0) + 1;
    const step = draft.simulationStep;
    const candidates = draft.phases.generate.candidates || [];
    if (step <= 4) {
      const candidate = candidates[step - 1];
      if (candidate) {
        const shouldFail = step === 3 && !candidate.retried;
        candidate.status = shouldFail ? 'failed' : 'complete';
        candidate.gradient = gradientForSeed(draft.id + '-' + step + '-' + (candidate.retried ? 'retry' : 'base'));
        draft.statusState = shouldFail ? 'partial_fail' : 'generating';
        draft.progressText = shouldFail ? '#' + step + ' 후보 생성 실패' : '#' + step + '/4 후보 생성 완료';
        draft.etaText = shouldFail ? '~40초' : '~1분';
      }
      const nextCandidate = candidates[step];
      if (nextCandidate && nextCandidate.status === 'idle') nextCandidate.status = 'generating';
    } else if (step === 5) {
      draft.phases.generate.status = 'complete';
      draft.phases.evaluate.status = 'complete';
      draft.statusState = 'complete';
      draft.progressText = '후보 4개 준비 완료';
      draft.etaText = '지금 피드백 가능';
    } else if (step === 6) {
      draft.phases.refine.status = draft.feedback.chips.length ? 'complete' : 'idle';
    }
    if (draft.phases.generate.status === 'complete' && draft.phases.evaluate.status === 'complete') {
      draft.phases.deliver.status = draft.privacy === 'gallery' ? 'complete' : draft.phases.deliver.status;
    }
    draft.modified = now();
    return draft;
  });
  return project;
}
function retryCandidate(projectId, candidateId) {
  const updated = updateProject(projectId, draft => {
    const candidate = draft.phases.generate.candidates.find(item => item.id === candidateId);
    if (!candidate) return draft;
    candidate.status = 'generating';
    candidate.retried = true;
    draft.statusState = 'generating';
    draft.progressText = candidate.label + ' 재생성 중';
    draft.etaText = '~35초';
    draft.lastSimulationAt = now() - 5000;
    draft.modified = now();
    return draft;
  });
  render();
  return updated;
}
function toggleFeedbackChip(projectId, chip) {
  updateProject(projectId, draft => {
    const chips = new Set(draft.feedback.chips);
    if (chips.has(chip)) chips.delete(chip); else chips.add(chip);
    draft.feedback.chips = Array.from(chips);
    draft.modified = now();
    return draft;
  });
  render();
}
function updateFeedbackField(projectId, field, value) {
  updateProject(projectId, draft => {
    draft.feedback[field] = value;
    draft.modified = now();
    return draft;
  });
}
function updatePrivacy(projectId, privacy) {
  updateProject(projectId, draft => {
    draft.privacy = privacy;
    if (privacy === 'gallery' && draft.phases.generate.status === 'complete') draft.phases.deliver.status = 'complete';
    draft.modified = now();
    return draft;
  });
  render();
}
function performProjectAction(projectId, action) {
  updateProject(projectId, draft => {
    if (action === 'approve') {
      draft.statusState = 'complete';
      draft.phases.evaluate.status = 'complete';
      draft.phases.refine.status = 'complete';
      draft.phases.deliver.status = 'complete';
      draft.progressText = '승인 완료, 전달 단계 준비됨';
      draft.etaText = '즉시 사용 가능';
    }
    if (action === 'regenerate') {
      draft.statusState = 'generating';
      draft.phases.generate.status = 'generating';
      draft.phases.evaluate.status = 'idle';
      draft.phases.refine.status = 'idle';
      draft.phases.deliver.status = 'idle';
      draft.phases.generate.candidates = draft.phases.generate.candidates.map((candidate, index) => ({ ...candidate, status: index === 0 ? 'generating' : 'idle', retried: false }));
      draft.progressText = '새 후보 조합을 생성합니다';
      draft.etaText = '~2분';
      draft.simulationStep = 0;
      draft.lastSimulationAt = now() - 5000;
    }
    if (action === 'direction') {
      draft.statusState = 'timeout';
      draft.progressText = '방향 수정 대기 중';
      draft.etaText = '입력 후 재생성';
    }
    draft.modified = now();
    return draft;
  });
  render();
}
function cloneGalleryItem(itemId) {
  const item = GALLERY_ITEMS.find(entry => entry.id === itemId);
  if (!item) return;
  const draft = {
    topic: item.category === '만화' ? ['sf'] : item.category === '스토리보드' ? ['drama'] : ['modern'],
    style: item.style === '수채화' ? ['watercolor'] : item.style === '잉크' ? ['ink'] : item.style === '사실주의' ? ['realism'] : item.style === '유화' ? ['oil'] : ['digital'],
    mood: item.mood === '미스터리' ? ['mystery'] : item.mood === '역동적' ? ['dynamic'] : ['warm'],
    custom: ''
  };
  saveWizardDraft(draft);
  state.wizardStep = 0;
  routeTo('/new');
}
function copyRecoveryUrl(token) {
  const url = location.href.split('#')[0] + '#/resume/' + token;
  if (navigator.clipboard?.writeText) {
    navigator.clipboard.writeText(url).then(() => alert('복구 링크를 복사했습니다.')).catch(() => prompt('복구 링크를 복사하세요.', url));
  } else {
    prompt('복구 링크를 복사하세요.', url);
  }
}
function handleResume(tokenValue) {
  const project = getProjects().find(entry => entry.recoveryToken === tokenValue);
  if (!project) {
    return wrapPage('<section class="page"><div class="empty-state"><h2>프로젝트를 찾을 수 없습니다</h2><p class="muted">복구 토큰이 만료되었거나 로컬 데이터가 삭제되었습니다.</p><div class="hero-actions"><a class="primary-btn" href="#/landing">랜딩으로 이동</a></div></div></section>');
  }
  sessionStorage.setItem(SESSION_KEYS.projectId, project.id);
  setTimeout(() => routeTo('/project/' + project.id), 900);
  return wrapPage('<section class="page"><div class="status-panel"><div class="status-banner"><span class="status-icon fade" style="color:var(--green)">✅</span><div><strong>세션을 복구했습니다</strong><div class="muted">잠시 후 프로젝트 화면으로 이동합니다.</div></div></div></div></section>');
}
function wrapPage(inner) { return inner; }
function renderLanding() {
  const recent = GALLERY_ITEMS.slice(0, 4).map(item => '<article class="thumb-card scroll-reveal"><div class="thumb-visual" style="background:' + item.gradient + '"></div><div class="thumb-content"><strong>' + item.title + '</strong><div class="meta-line"><span>' + item.category + '</span><span>❤️ ' + item.likes + '</span></div></div></article>').join('');
  return wrapPage('<section class="page">    <div class="hero-card">      <div class="hero-grid">        <div class="hero-copy">          <span class="eyebrow">프로토타입 · 다중 사용자 UI · Phase 1</span>          <h1>프롬프트를 쓰지 마세요. 고르세요.</h1>          <p>3단계 카드 선택으로 창의적 산출물 생성. 게이트 피드백과 반복 개선 루프로 결과물 품질을 안정적으로 끌어올립니다.</p>          <div class="hero-actions"><a class="primary-btn" href="#/new">바로 체험하기</a><a class="secondary-btn" href="#/dashboard">내 프로젝트 보기</a></div>          <div class="tags"><span class="tag">만화</span><span class="tag">일러스트</span><span class="tag">스토리보드</span><span class="tag">글쓰기</span></div>        </div>        <div class="loop-visual" aria-hidden="true">          <svg class="loop-ring" viewBox="0 0 420 420">            <defs><linearGradient id="loopLine" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#6366f1"></stop><stop offset="100%" stop-color="#14b8a6"></stop></linearGradient></defs>            <circle cx="210" cy="210" r="128" fill="none" stroke="url(#loopLine)" stroke-width="18" stroke-linecap="round" stroke-dasharray="620" stroke-dashoffset="110"></circle>            <g class="orbit-dot"><circle cx="210" cy="82" r="16" fill="#818cf8"></circle></g>            <g class="loop-node"><circle cx="210" cy="58" r="36" fill="rgba(59,130,246,0.16)" stroke="#3b82f6"></circle><text x="210" y="64" text-anchor="middle">Define</text></g>            <g class="loop-node"><circle cx="326" cy="126" r="36" fill="rgba(168,85,247,0.16)" stroke="#a855f7"></circle><text x="326" y="132" text-anchor="middle">Generate</text></g>            <g class="loop-node"><circle cx="326" cy="294" r="36" fill="rgba(245,158,11,0.16)" stroke="#f59e0b"></circle><text x="326" y="300" text-anchor="middle">Evaluate</text></g>            <g class="loop-node"><circle cx="94" cy="294" r="36" fill="rgba(34,197,94,0.16)" stroke="#22c55e"></circle><text x="94" y="300" text-anchor="middle">Refine</text></g>            <g class="loop-node"><circle cx="94" cy="126" r="36" fill="rgba(20,184,166,0.16)" stroke="#14b8a6"></circle><text x="94" y="132" text-anchor="middle">Deliver</text></g>          </svg>        </div>      </div>    </div>    <section class="panel" style="padding:22px;">      <div class="section-head"><h3>최근 갤러리 미리보기</h3><a class="ghost-btn" href="#/gallery">전체 보기</a></div>      <div class="gallery-strip">' + recent + '</div>    </section>  </section>');
}
function renderTutorial() {
  const settings = getSettings();
  const root = document.getElementById('tutorialRoot');
  if (settings.tutorial_seen) { root.innerHTML = ''; return; }
  const slide = TUTORIAL_SLIDES[state.tutorialIndex || 0];
  root.innerHTML = '<aside class="tutorial"><div class="section-head"><strong>튜토리얼</strong><button class="ghost-btn" type="button" data-action="dismiss-tutorial">닫기</button></div><h3 style="margin:0;">' + slide.title + '</h3><p class="muted">' + slide.desc + '</p><div class="tutorial-dots">' + TUTORIAL_SLIDES.map((_, index) => '<span class="tutorial-dot ' + ((state.tutorialIndex || 0) === index ? 'active' : '') + '"></span>').join('') + '</div><div class="hero-actions"><button class="secondary-btn" type="button" data-action="next-tutorial">다음</button><button class="primary-btn" type="button" data-action="finish-tutorial">확인</button></div></aside>';
  clearTimeout(state.tutorialTimer);
  state.tutorialTimer = setTimeout(() => finishTutorial(), 8000);
}
function finishTutorial() {
  const settings = getSettings();
  settings.tutorial_seen = true;
  saveSettings(settings);
  document.getElementById('tutorialRoot').innerHTML = '';
}
function renderNewProject() {
  const draft = getWizardDraft();
  const step = WIZARD_STEPS[state.wizardStep];
  const cards = step.cards.map(card => {
    const active = draft[step.key].includes(card.id);
    const customInput = card.id === 'custom' && active ? '<input class="custom-input" type="text" placeholder="원하는 주제를 입력하세요" value="' + escapeHtml(draft.custom || '') + '" data-custom-topic />' : '';
    return '<div class="select-card ' + (active ? 'active' : '') + '"><button type="button" class="ghost-btn" style="width:100%;min-height:88px;display:grid;gap:8px;justify-items:start;text-align:left;background:transparent;border:none;padding:0;" data-step="' + step.key + '" data-card="' + card.id + '"><span class="emoji">' + card.emoji + '</span><strong>' + card.label + '</strong><span class="muted">' + card.desc + '</span></button>' + customInput + '</div>';
  }).join('');
  const selectedTopic = draft.topic.map(id => labelFor('topic', id)).join(' · ') || (draft.custom || '아직 선택 없음');
  const selectedStyle = draft.style.map(id => labelFor('style', id)).join(' · ') || '아직 선택 없음';
  const selectedMood = draft.mood.map(id => labelFor('mood', id)).join(' · ') || '아직 선택 없음';
  return wrapPage('<section class="page">    <div class="page-title"><div><div class="step-pill">Step ' + (state.wizardStep + 1) + '/3</div><h2>' + step.title + '</h2><p class="muted">다중 선택이 가능하며 선택한 조합은 실시간으로 프리뷰에 반영됩니다.</p></div><button type="button" class="secondary-btn" data-action="wizard-random">AI가 추천해줘</button></div>    <div class="wizard-layout">      <div class="wizard-card">        <div class="step-track">' + WIZARD_STEPS.map((_, index) => '<div class="step-bar"><span style="width:' + (state.wizardStep >= index ? '100%' : '0%') + '"></span></div>').join('') + '</div>        <div class="card-grid" style="margin-top:18px;">' + cards + '</div>        <div class="info-bar" style="margin-top:18px;"><span>예상 생성 시간: ~2분</span><span>결과물 수: 4개 후보</span></div>        <div class="hero-actions" style="margin-top:18px;">' + (state.wizardStep > 0 ? '<button type="button" class="ghost-btn" data-action="wizard-prev">이전 단계</button>' : '<a class="ghost-btn" href="#/landing">랜딩으로</a>') + (state.wizardStep < 2 ? '<button type="button" class="primary-btn" data-action="wizard-next">다음 단계</button>' : '<button type="button" class="primary-btn" data-action="create-project">🚀 생성 시작</button>') + '</div>      </div>      <aside class="status-panel">        <div class="preview-stack">          <div class="preview-card"><p class="combo-title">' + escapeHtml(buildTitle(draft)) + '</p><p class="muted">선택 조합 프리뷰</p><div class="tags"><span class="tag">주제: ' + escapeHtml(selectedTopic) + '</span><span class="tag">화풍: ' + escapeHtml(selectedStyle) + '</span><span class="tag">분위기: ' + escapeHtml(selectedMood) + '</span></div></div>          <div class="candidate-visual" style="border-radius:18px;background:' + gradientForSeed(selectedTopic + selectedStyle + selectedMood) + ';">미리보기</div>          <div class="recovery-box"><strong>현재 조합</strong><p class="muted">이 페이지를 벗어나도 선택값은 세션에 보관됩니다.</p></div>        </div>      </aside>    </div>  </section>');
}
function renderDashboard() {
  const projects = getProjects();
  const filters = ['전체', '진행중', '완료'];
  const filtered = projects.filter(project => {
    if (state.dashboardFilter === '진행중') return overallStatus(project) !== 'complete';
    if (state.dashboardFilter === '완료') return overallStatus(project) === 'complete';
    return true;
  });
  const cards = filtered.length ? filtered.map(project => '<article class="project-card scroll-reveal"><div class="project-visual" style="background:' + (project.galleryGradient || gradientForSeed(project.id)) + '"></div><div class="project-content"><div class="meta-line"><strong>' + escapeHtml(project.title) + '</strong><span>' + statusMarkup(overallStatus(project)) + '</span></div><div class="progress-mini"><span style="width:' + projectCompletion(project) + '%"></span></div><div class="meta-line"><span>진행률 ' + projectCompletion(project) + '%</span><span>' + formatDate(project.modified) + '</span></div><a class="primary-btn" href="#/project/' + project.id + '">프로젝트 열기</a></div></article>').join('') : '<div class="empty-state"><h2>아직 프로젝트가 없습니다</h2><p class="muted">새 프로젝트를 만들어 첫 루프를 시작하세요.</p><a class="primary-btn" href="#/new">새 프로젝트</a></div>';
  return wrapPage('<section class="page"><div class="page-title"><div><h2>내 프로젝트</h2><p class="muted">localStorage에 저장된 프로젝트를 기반으로 진행 상태를 이어갑니다.</p></div><a class="primary-btn" href="#/new">새 프로젝트</a></div><div class="filter-row">' + filters.map(filter => '<button type="button" class="filter-chip ' + (state.dashboardFilter === filter ? 'active' : '') + '" data-dashboard-filter="' + filter + '">' + filter + '</button>').join('') + '</div><div class="project-grid">' + cards + '</div></section>');
}
function renderProject() {
  const projectId = state.params.id;
  let project = getProjects().find(item => item.id === projectId);
  if (!project) {
    return wrapPage('<section class="page"><div class="empty-state"><h2>프로젝트를 찾을 수 없습니다</h2><p class="muted">복구 링크나 대시보드에서 다시 접근해 주세요.</p><a class="primary-btn" href="#/dashboard">대시보드로 이동</a></div></section>');
  }
  project = ensureProjectSimulation(projectId) || project;
  const phasesMarkup = PHASES.map((phase, index) => {
    const status = project.phases[phase.key]?.status || 'idle';
    const stateClass = status === 'complete' ? 'complete' : project.phases[phase.key]?.status === 'generating' || (phase.key === 'generate' && overallStatus(project) === 'generating') ? 'active' : 'pending';
    const iconStatus = phase.key === 'generate' && overallStatus(project) === 'partial_fail' ? 'partial_fail' : overallStatus(project) === 'timeout' && phase.key === 'refine' ? 'timeout' : overallStatus(project) === 'network_error' && phase.key === 'generate' ? 'network_error' : status === 'complete' ? 'complete' : status === 'generating' ? 'generating' : 'idle';
    return '<div class="phase-item ' + stateClass + '" style="color:' + phase.color + ';"><div class="phase-num">0' + (index + 1) + '</div><div class="phase-name">' + phase.label + '</div><div class="phase-status">' + statusMarkup(iconStatus) + '</div></div>';
  }).join('');
  const candidates = project.phases.generate.candidates.map((candidate, index) => {
    const candidateStatus = candidate.status === 'failed' ? 'failed' : candidate.status === 'complete' ? 'complete' : candidate.status === 'generating' ? 'generating' : 'idle';
    const label = candidateStatus === 'complete' ? '후보 #' + (index + 1) : candidateStatus === 'failed' ? '실패' : candidateStatus === 'generating' ? '생성 중' : '대기';
    const body = candidateStatus === 'failed'
      ? '<button type="button" class="secondary-btn retry-btn" data-retry="' + candidate.id + '">재시도</button>'
      : '<div class="muted">' + (candidateStatus === 'complete' ? '준비 완료' : '엔진 대기') + '</div>';
    return '<article class="candidate-card scroll-reveal"><div class="candidate-visual" style="background:' + (candidate.gradient || 'linear-gradient(135deg, rgba(51,65,85,0.7), rgba(15,23,42,0.95))') + ';">' + label + '</div><div class="candidate-meta"><strong>후보 ' + (index + 1) + '</strong><div class="meta-line"><span>' + statusMarkup(candidateStatus) + '</span><span>' + (candidateStatus === 'complete' ? '선택 가능' : candidateStatus === 'failed' ? '복구 필요' : '진행 중') + '</span></div>' + body + '</div></article>';
  }).join('');
  const status = STATUS_META[overallStatus(project)] || STATUS_META.idle;
  const chips = FEEDBACK_CHIPS.map(chip => '<button type="button" class="feedback-chip ' + (project.feedback.chips.includes(chip) ? 'selected' : '') + '" data-chip="' + chip + '">' + chip + '</button>').join('');
  const recoveryUrl = location.href.split('#')[0] + '#/resume/' + project.recoveryToken;
  return wrapPage('<section class="page project-hero">    <div class="page-title"><div><h2>' + escapeHtml(project.title) + '</h2><p class="muted">프로젝트 ID: ' + project.id + ' · 마지막 수정 ' + formatDate(project.modified) + '</p></div><a class="ghost-btn" href="#/dashboard">프로젝트 목록</a></div>    <div class="panel" style="padding:22px;">      <div class="phase-pipeline">' + phasesMarkup + '</div>    </div>    <div class="project-layout">      <section class="panel" style="padding:22px;">        <div class="section-head"><h3>후보 결과물</h3><span class="muted">2 x 2 그리드</span></div>        <div class="candidate-grid" style="margin-top:16px;">' + candidates + '</div>      </section>      <aside class="status-panel">        <div class="status-banner" style="border-color:' + status.color + '; background:rgba(15,23,42,0.92);"><span class="status-icon ' + status.anim + '" style="color:' + status.color + '">' + status.icon + '</span><div><strong>현재 단계: ' + escapeHtml(project.progressText) + '</strong><div class="muted">남은 예상 시간: ' + escapeHtml(project.etaText) + '</div></div></div>        <div class="panel" style="padding:18px;">          <div class="stack-title"><h3>게이트 피드백</h3></div>          <div class="feedback-grid" style="margin-top:12px;">' + chips + '</div>          <div style="margin-top:16px; display:grid; gap:12px;">            <label class="slider-row"><span>방향성</span><input type="range" min="1" max="5" value="' + project.feedback.rating_direction + '" data-range="rating_direction"><strong>' + '★'.repeat(project.feedback.rating_direction) + '</strong></label>            <label class="slider-row"><span>품질</span><input type="range" min="1" max="5" value="' + project.feedback.rating_quality + '" data-range="rating_quality"><strong>' + '★'.repeat(project.feedback.rating_quality) + '</strong></label>          </div>          <textarea rows="4" placeholder="선택 코멘트를 남기세요" data-comment style="margin-top:14px;">' + escapeHtml(project.feedback.comment || '') + '</textarea>          <div class="hero-actions" style="margin-top:14px;"><button type="button" class="primary-btn" data-project-action="approve">✅ 승인</button><button type="button" class="secondary-btn" data-project-action="regenerate">🔄 재생성</button><button type="button" class="ghost-btn" data-project-action="direction">✏️ 방향 수정</button></div>        </div>        <div class="recovery-box"><strong>Recovery URL</strong><p class="muted">' + escapeHtml(recoveryUrl) + '</p><button type="button" class="secondary-btn" data-copy-token="' + project.recoveryToken + '">클립보드 복사</button></div>        <div class="privacy-box"><strong>공개 설정</strong><div class="radio-group" style="margin-top:12px;">' + [
          { key: 'private', label: '비공개', desc: '나만 볼 수 있어요' },
          { key: 'link', label: '링크 공유', desc: '링크 아는 사람만' },
          { key: 'gallery', label: '갤러리 공개', desc: '모두가 볼 수 있어요' }
        ].map(item => '<label class="radio-card ' + (project.privacy === item.key ? 'active' : '') + '"><input type="radio" name="privacy" value="' + item.key + '" ' + (project.privacy === item.key ? 'checked' : '') + ' style="margin-right:8px;" data-privacy="' + item.key + '"><strong>' + item.label + '</strong><div class="muted">' + item.desc + '</div></label>').join('') + '</div></div>      </aside>    </div>  </section>');
}
function renderGallery() {
  const filters = ['전체', '카테고리', '화풍', '최신', '인기'];
  const list = GALLERY_ITEMS.filter(item => {
    const query = state.gallerySearch.trim().toLowerCase();
    const matchesFilter = state.galleryFilter === '전체' || state.galleryFilter === '최신' && item.sort === '최신' || state.galleryFilter === '인기' && item.sort === '인기' || state.galleryFilter === '카테고리' || state.galleryFilter === '화풍';
    const matchesSearch = !query || [item.title, item.category, item.style].join(' ').toLowerCase().includes(query);
    return matchesFilter && matchesSearch;
  });
  const cards = list.map(item => '<article class="gallery-card scroll-reveal"><div class="gallery-visual" style="background:' + item.gradient + '; min-height:' + (180 + (item.likes % 3) * 36) + 'px;"></div><div class="gallery-content"><div class="meta-line"><strong>' + escapeHtml(item.title) + '</strong><span>❤️ ' + item.likes + '</span></div><div class="tags"><span class="tag">' + item.category + '</span><span class="tag">' + item.style + '</span><span class="tag">' + item.sort + '</span></div><div class="hero-actions"><button type="button" class="secondary-btn" data-clone-gallery="' + item.id + '">복제</button><button type="button" class="ghost-btn" data-open-gallery="' + item.id + '">상세 보기</button></div></div></article>').join('');
  return wrapPage('<section class="page"><div class="page-title"><div><h2>공개 갤러리</h2><p class="muted">Masonry 그리드로 최근 공유 결과물을 탐색합니다.</p></div></div><div class="filter-row"><input class="search-input" type="text" placeholder="검색" value="' + escapeHtml(state.gallerySearch) + '" data-gallery-search>' + filters.map(filter => '<button type="button" class="filter-chip ' + (state.galleryFilter === filter ? 'active' : '') + '" data-gallery-filter="' + filter + '">' + filter + '</button>').join('') + '</div><div class="masonry">' + cards + '</div></section>');
}
function renderSettings() {
  return wrapPage('<section class="page"><div class="page-title"><div><h2>설정</h2><p class="muted">Phase 1에서는 다크 테마와 한국어만 지원합니다.</p></div></div><div class="settings-list"><div class="settings-card"><div class="section-head"><h3>테마</h3><span class="disabled-pill">다크 전용</span></div><p class="muted">PRD 8.1 색상 팔레트를 기준으로 고정 적용됩니다.</p></div><div class="settings-card"><div class="section-head"><h3>언어</h3><span class="disabled-pill">한국어 전용</span></div><p class="muted">Phase 1 범위에서는 모든 UI를 한국어로 유지합니다.</p></div><div class="settings-card"><div class="section-head"><h3>계정</h3><span class="disabled-pill">GitHub 연동 · Phase 2</span></div><p class="muted">계정 기반 프로젝트 공유와 갤러리 업로드는 다음 단계에서 열립니다.</p></div><div class="settings-card"><div class="section-head"><h3>Discord</h3><span class="disabled-pill">연동 예정 · Phase 2.5</span></div><p class="muted">실시간 승인 알림과 스레드 협업은 추후 연결됩니다.</p></div><div class="settings-card"><div class="section-head"><h3>데이터 초기화</h3><button type="button" class="danger-btn" data-clear-data>모든 데이터 삭제</button></div><p class="muted">프로젝트, 설정, 세션 데이터를 모두 제거합니다.</p></div></div></section>');
}
function openGalleryModal(itemId) {
  state.modalItem = GALLERY_ITEMS.find(item => item.id === itemId) || null;
  renderModal();
}
function renderModal() {
  const modal = document.getElementById('galleryModal');
  const item = state.modalItem;
  if (!item) {
    modal.className = 'modal';
    modal.innerHTML = '';
    return;
  }
  modal.className = 'modal open';
  modal.innerHTML = '<div class="modal-card"><div class="section-head"><h3>' + escapeHtml(item.title) + '</h3><button type="button" class="ghost-btn" data-close-modal>닫기</button></div><div class="modal-visual" style="background:' + item.gradient + ';"></div><div class="tags"><span class="tag">' + item.category + '</span><span class="tag">' + item.style + '</span><span class="tag">좋아요 ' + item.likes + '</span></div><p class="muted">제작 과정 타임라인은 Phase 2에서 확장됩니다. 현재는 복제 후 새 프로젝트에서 카드 조합을 수정할 수 있습니다.</p><div class="hero-actions"><button type="button" class="primary-btn" data-clone-gallery="' + item.id + '">이 조합으로 시작</button></div></div>';
}
function render() {
  const parsed = parseHash();
  state.route = parsed.path;
  state.params = parsed.params;
  renderNav();
  const app = document.getElementById('app');
  app.classList.remove('is-ready');
  let markup = '';
  if (state.route === '/landing') markup = renderLanding();
  if (state.route === '/new') markup = renderNewProject();
  if (state.route === '/dashboard') markup = renderDashboard();
  if (state.route === '/project') markup = renderProject();
  if (state.route === '/gallery') markup = renderGallery();
  if (state.route === '/settings') markup = renderSettings();
  if (state.route === '/resume') markup = handleResume(state.params.token);
  app.innerHTML = markup;
  setTimeout(() => app.classList.add('is-ready'), 20);
  renderTutorial();
  renderModal();
  hydrateScrollReveal();
}
function hydrateScrollReveal() {
  const observer = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('visible');
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.scroll-reveal').forEach(node => observer.observe(node));
}
function toggleWizardCard(stepKey, cardId) {
  const draft = getWizardDraft();
  const current = new Set(draft[stepKey]);
  if (current.has(cardId)) current.delete(cardId); else current.add(cardId);
  draft[stepKey] = Array.from(current);
  if (stepKey === 'topic' && !draft.topic.includes('custom')) draft.custom = '';
  saveWizardDraft(draft);
  render();
}
function randomizeWizard() {
  const draft = { topic: [], style: [], mood: [], custom: '' };
  WIZARD_STEPS.forEach(step => {
    const randomCard = step.cards[Math.floor(Math.random() * step.cards.length)];
    if (randomCard.id === 'custom') {
      draft[step.key] = ['custom'];
      draft.custom = '실험적 아트북';
    } else {
      draft[step.key] = [randomCard.id];
    }
  });
  saveWizardDraft(draft);
  render();
}
function nextWizardStep() {
  state.wizardStep = Math.min(2, state.wizardStep + 1);
  render();
}
function prevWizardStep() {
  state.wizardStep = Math.max(0, state.wizardStep - 1);
  render();
}
function createProject() {
  const draft = getWizardDraft();
  if (!draft.topic.length && !draft.custom) { alert('주제를 하나 이상 선택하세요.'); return; }
  if (!draft.style.length) { alert('화풍을 하나 이상 선택하세요.'); return; }
  if (!draft.mood.length) { alert('분위기를 하나 이상 선택하세요.'); return; }
  const project = createProjectFromDraft(draft);
  resetWizardDraft();
  routeTo('/project/' + project.id);
}
function attachEvents() {
  document.body.addEventListener('click', event => {
    const target = event.target.closest('[data-action],[data-step],[data-retry],[data-chip],[data-copy-token],[data-project-action],[data-dashboard-filter],[data-gallery-filter],[data-open-gallery],[data-close-modal],[data-clone-gallery],[data-clear-data]');
    if (!target) return;
    if (target.dataset.step && target.dataset.card) { toggleWizardCard(target.dataset.step, target.dataset.card); return; }
    if (target.dataset.retry) { retryCandidate(state.params.id, target.dataset.retry); return; }
    if (target.dataset.chip) { toggleFeedbackChip(state.params.id, target.dataset.chip); return; }
    if (target.dataset.copyToken) { copyRecoveryUrl(target.dataset.copyToken); return; }
    if (target.dataset.projectAction) { performProjectAction(state.params.id, target.dataset.projectAction); return; }
    if (target.dataset.dashboardFilter) { state.dashboardFilter = target.dataset.dashboardFilter; render(); return; }
    if (target.dataset.galleryFilter) { state.galleryFilter = target.dataset.galleryFilter; render(); return; }
    if (target.dataset.openGallery) { openGalleryModal(target.dataset.openGallery); return; }
    if (target.dataset.closeModal) { state.modalItem = null; renderModal(); return; }
    if (target.dataset.cloneGallery) { cloneGalleryItem(target.dataset.cloneGallery); state.modalItem = null; renderModal(); return; }
    if (target.dataset.clearData !== undefined) {
      if (confirm('모든 프로젝트와 설정을 삭제할까요?')) {
        localStorage.removeItem(STORAGE_KEYS.projects);
        localStorage.removeItem(STORAGE_KEYS.settings);
        sessionStorage.removeItem(SESSION_KEYS.projectId);
        sessionStorage.removeItem(SESSION_KEYS.wizard);
        state.dashboardFilter = '전체';
        state.galleryFilter = '전체';
        routeTo('/landing');
      }
      return;
    }
    const action = target.dataset.action;
    if (action === 'wizard-random') randomizeWizard();
    if (action === 'wizard-next') nextWizardStep();
    if (action === 'wizard-prev') prevWizardStep();
    if (action === 'create-project') createProject();
    if (action === 'dismiss-tutorial' || action === 'finish-tutorial') finishTutorial();
    if (action === 'next-tutorial') {
      state.tutorialIndex = ((state.tutorialIndex || 0) + 1) % TUTORIAL_SLIDES.length;
      renderTutorial();
    }
  });
  document.body.addEventListener('input', event => {
    const target = event.target;
    if (target.matches('[data-custom-topic]')) {
      const draft = getWizardDraft();
      draft.custom = target.value;
      saveWizardDraft(draft);
      return;
    }
    if (target.matches('[data-range]')) {
      updateFeedbackField(state.params.id, target.dataset.range, Number(target.value));
      render();
      return;
    }
    if (target.matches('[data-comment]')) {
      updateFeedbackField(state.params.id, 'comment', target.value);
      return;
    }
    if (target.matches('[data-gallery-search]')) {
      state.gallerySearch = target.value;
      render();
      return;
    }
  });
  document.body.addEventListener('change', event => {
    const target = event.target;
    if (target.matches('[data-privacy]')) updatePrivacy(state.params.id, target.value);
  });
  window.addEventListener('hashchange', render);
  window.addEventListener('keydown', event => {
    if (event.key === 'Escape') {
      state.modalItem = null;
      renderModal();
    }
  });
  document.getElementById('githubPlaceholder').addEventListener('click', () => alert('GitHub 로그인은 Phase 2에서 연결됩니다.'));
}
function bootstrap() {
  const settings = getSettings();
  saveSettings(settings);
  if (!sessionStorage.getItem(SESSION_KEYS.wizard)) resetWizardDraft();
  attachEvents();
  render();
  setInterval(() => {
    if (state.route === '/project' && state.params.id) render();
  }, 4000);
}
bootstrap();
</script>
</body>
</html>